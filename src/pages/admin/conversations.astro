---
import AdminPage from '../../layouts/AdminPage.astro';
import AdminLayout from '../../components/admin/AdminLayout';

const leadId = Astro.url.searchParams.get('leadId');

// Fetch conversations from API
let conversationsData: {
  conversations: Array<{
    id: string;
    lead: { name: string | null; email: string; company: string | null };
    status: string;
    awaitingReply: boolean;
    messages: Array<{
      id: string;
      role: string;
      source: string;
      content: string;
      createdAt: Date;
    }>;
  }>;
  pagination: {
    page: number;
    limit: number;
    total: number;
    totalPages: number;
  };
} = { conversations: [], pagination: { page: 1, limit: 25, total: 0, totalPages: 0 } };

let error: string | null = null;

try {
  const url = new URL('/api/admin/conversations', Astro.url.origin);
  if (leadId) url.searchParams.set('leadId', leadId);

  const response = await fetch(url.toString());
  if (response.ok) {
    conversationsData = await response.json();
  } else {
    const errData = await response.json().catch(() => ({ error: 'Failed to fetch conversations' }));
    error = errData.error || `Error ${response.status}`;
  }
} catch (e) {
  error = 'Network error. Please try again.';
}

// Select first conversation or the one matching leadId
const selectedConv = conversationsData.conversations.length > 0 ? conversationsData.conversations[0] : null;

const statusColors: Record<string, string> = {
  new: 'bg-blue-100 text-blue-800',
  contacted: 'bg-yellow-100 text-yellow-800',
  customer_waiting: 'bg-orange-100 text-orange-800',
  scheduled: 'bg-green-100 text-green-800',
  closed_won: 'bg-green-100 text-green-800',
  closed_lost: 'bg-gray-100 text-gray-600',
  escalated: 'bg-red-100 text-red-800',
  opted_out: 'bg-gray-100 text-gray-400',
};

const statusLabels: Record<string, string> = {
  new: 'New',
  contacted: 'Contacted',
  customer_waiting: 'Customer Waiting',
  scheduled: 'Scheduled',
  closed_won: 'Closed Won',
  closed_lost: 'Closed Lost',
  escalated: 'Escalated',
  opted_out: 'Opted Out',
};
---

<AdminPage title="Conversations" currentPath="/admin/conversations">
  <AdminLayout currentPath="/admin/conversations">
    <div class="p-8">
      <!-- Header -->
      <div class="mb-8">
        <h1 class="text-3xl font-bold font-heading text-charcoal mb-2">Conversations</h1>
        <p class="text-gray-500">View and manage lead conversations</p>
      </div>

      <!-- Error State -->
      {error && (
        <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg">
          <p class="text-sm text-red-600">{error}</p>
        </div>
      )}

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Conversation List -->
        <div class="lg:col-span-1">
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="p-4 border-b border-gray-100">
              <h2 class="text-sm font-semibold text-charcoal">Active Conversations</h2>
            </div>
            {conversationsData.conversations.length === 0 ? (
              <div class="p-8 text-center text-gray-400">
                <p class="text-sm">No conversations yet.</p>
              </div>
            ) : (
              <div class="divide-y divide-gray-100 max-h-[600px] overflow-y-auto">
                {conversationsData.conversations.map((conv) => {
                  const lastMessage = conv.messages.length > 0 ? conv.messages[conv.messages.length - 1] : null;
                  return (
                    <a
                      href={`/admin/conversations?leadId=${conv.id}`}
                      class={`block p-4 hover:bg-gray-50 transition-colors ${conv.status === 'new' ? 'bg-blue-50/50' : ''}`}
                    >
                      <div class="flex items-start justify-between mb-2">
                        <div class="flex items-center gap-2">
                          <div class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center text-xs font-medium text-gray-600">
                            {(conv.lead.name || conv.lead.email).charAt(0).toUpperCase()}
                          </div>
                          <div>
                            <p class="font-medium text-charcoal text-sm">{conv.lead.name || 'Unknown'}</p>
                            <p class="text-xs text-gray-500">{conv.lead.company || conv.lead.email}</p>
                          </div>
                        </div>
                        {conv.awaitingReply && (
                          <span class="w-2 h-2 bg-pounce-orange rounded-full"></span>
                        )}
                      </div>
                      {lastMessage && (
                        <>
                          <p class="text-sm text-gray-600 line-clamp-2">{lastMessage.content}</p>
                          <div class="mt-2 flex items-center gap-2">
                            <span class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-medium ${statusColors[conv.status]}`}>
                              {statusLabels[conv.status]}
                            </span>
                            <span class="text-xs text-gray-400">
                              {new Date(lastMessage.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}
                            </span>
                          </div>
                        </>
                      )}
                    </a>
                  );
                })}
              </div>
            )}
          </div>
        </div>

        <!-- Conversation Detail -->
        <div class="lg:col-span-2">
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 flex flex-col h-[600px]">
            {selectedConv ? (
              <>
                <!-- Conversation Header -->
                <div class="p-4 border-b border-gray-100 flex items-center justify-between">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center text-sm font-medium text-gray-600">
                      {(selectedConv.lead.name || selectedConv.lead.email).charAt(0).toUpperCase()}
                    </div>
                    <div>
                      <p class="font-medium text-charcoal">{selectedConv.lead.name || 'Unknown'}</p>
                      <p class="text-sm text-gray-500">{selectedConv.lead.email}</p>
                    </div>
                  </div>
                  <div class="flex items-center gap-2">
                    <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${statusColors[selectedConv.status]}`}>
                      {statusLabels[selectedConv.status]}
                    </span>
                  </div>
                </div>

                <!-- Messages -->
                <div class="flex-1 overflow-y-auto p-4 space-y-4">
                  {selectedConv.messages.map((message) => (
                    <div class={`flex ${message.source === 'customer' ? 'justify-start' : 'justify-end'}`}>
                      <div class={`max-w-[70%] rounded-2xl px-4 py-3 ${
                        message.source === 'customer'
                          ? 'bg-gray-100 text-charcoal rounded-bl-none'
                          : message.source === 'ai'
                          ? 'bg-pounce-orange/10 text-charcoal rounded-br-none border border-pounce-orange/20'
                          : 'bg-blue-100 text-charcoal rounded-br-none'
                      }`}>
                        <p class="text-sm">{message.content}</p>
                        <div class="flex items-center gap-2 mt-1">
                          <span class="text-xs text-gray-400">
                            {new Date(message.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}
                          </span>
                          {message.source === 'ai' && (
                            <span class="text-xs text-pounce-orange font-medium">AI</span>
                          )}
                          {message.source === 'human' && (
                            <span class="text-xs text-blue-600 font-medium">You</span>
                          )}
                        </div>
                      </div>
                    </div>
                  ))}
                </div>

                <!-- Reply Input -->
                <div class="p-4 border-t border-gray-100">
                  <div class="flex gap-3">
                    <input
                      type="text"
                      placeholder="Type your reply..."
                      class="flex-1 px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
                    />
                    <button class="px-6 py-3 bg-pounce-orange text-white rounded-lg font-medium hover:bg-pounce-orange-dark transition-colors text-sm">
                      Send
                    </button>
                  </div>
                  <p class="text-xs text-gray-400 mt-2">Press Enter to send, Shift+Enter for new line</p>
                </div>
              </>
            ) : (
              <div class="flex-1 flex items-center justify-center text-gray-400">
                <div class="text-center">
                  <svg class="w-12 h-12 mx-auto mb-3 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                  </svg>
                  <p class="text-sm">Select a conversation to view messages</p>
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  </AdminLayout>
</AdminPage>
