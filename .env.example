# Boot config — only what's needed before the setup wizard runs.
# All other settings (LLM keys, email keys, booking, etc.) are configured
# through the setup wizard at /admin/setup and stored in the database.

# Database (required)
DATABASE_URL=

# Auth (required — random 32+ char string for production)
SESSION_SECRET=

# License (required for production — get yours at pouncefirst.com)
POUNCE_LICENSE_KEY=