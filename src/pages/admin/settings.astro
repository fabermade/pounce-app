---
import AdminPage from '../../layouts/AdminPage.astro';
import AdminLayout from '../../components/admin/AdminLayout';
import KnowledgeSources from '../../components/admin/settings/KnowledgeSources.astro';
import FaqSection from '../../components/admin/settings/FaqSection.astro';
import BookingSection from '../../components/admin/settings/BookingSection.astro';
import BookingConfig from '../../components/admin/settings/BookingConfig.astro';
import AgentMode from '../../components/admin/settings/AgentMode.astro';
import IntegrationsSection from '../../components/admin/settings/IntegrationsSection.astro';
import ServicesSection from '../../components/admin/settings/ServicesSection.astro';
import EscalationSection from '../../components/admin/settings/EscalationSection.astro';
import ToneSection from '../../components/admin/settings/ToneSection.astro';
import { db, businessConfig } from '../../lib/db/index.js';
import { eq } from 'drizzle-orm';

// Read config directly from DB — no fetch() (SSR pages don't forward cookies)
const configRows = await db.select().from(businessConfig);
const configMap: Record<string, unknown> = {};
for (const row of configRows) {
  configMap[row.key] = row.value;
}

const config = configMap;

const settingsSections = [
  { id: 'business', label: 'Business Identity' },
  { id: 'tone', label: 'Tone & Voice' },
  { id: 'knowledge', label: 'Knowledge Sources' },
  { id: 'services', label: 'Services & Pricing' },
  { id: 'faq', label: 'FAQ' },
  { id: 'escalation', label: 'Escalation Rules' },
  { id: 'booking', label: 'Booking' },
  { id: 'integrations', label: 'Integrations' },
  { id: 'agent', label: 'Agent Mode' },
];

// Type-safe config accessors
const business = (config.business || {}) as Record<string, string>;
const tone = (config.tone || {}) as Record<string, unknown>;
const services = (config.services || []) as Array<{ name: string; description?: string; price?: string }>;
const faq = (config.faq || []) as Array<Record<string, string>>;
const escalation = (config.escalation || {}) as Record<string, unknown>;
const booking = (config.booking || {}) as Record<string, string>;
const providers = (config.providers || {}) as Record<string, string>;
const agent = (config.agent || {}) as Record<string, unknown>;

const toneDos = (tone.dos || []) as string[];
const toneDonts = (tone.donts || []) as string[];
const escalationTriggers = (escalation.triggerPhrases || []) as string[];

// Knowledge sources
const knowledge = (config.knowledge || {}) as Record<string, unknown>;
const knowledgeLinks = (knowledge.links || []) as Array<{ url: string; label: string; description?: string }>;
const knowledgeTexts = (knowledge.texts || []) as Array<{ title: string; content: string }>;

// Provider key status — direct DB read shows real env:KEY refs
const llmKeySet = !!(providers.llmApiKey);
const emailKeySet = !!(providers.emailApiKey);
---

<AdminPage title="Settings" currentPath="/admin/settings">
  <AdminLayout currentPath="/admin/settings">
    <div class="p-8">
      <!-- Header -->
      <div class="mb-8">
        <h1 class="text-3xl font-bold font-heading text-charcoal mb-2">Settings</h1>
        <p class="text-gray-500">Configure your AI lead response agent</p>
      </div>

      <!-- Save Status -->
      <div id="save-status" class="hidden mb-6 p-4 rounded-lg"></div>

      <form id="settings-form" class="grid grid-cols-1 lg:grid-cols-4 gap-8">
        <!-- Settings Navigation -->
        <div class="lg:col-span-1">
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden sticky top-4">
            <nav class="divide-y divide-gray-100">
              {settingsSections.map((section, index) => (
                <button
                  type="button"
                  data-section-nav={section.id}
                  class={`w-full text-left px-4 py-3 text-sm font-medium transition-colors hover:bg-gray-50 ${
                    index === 0 ? 'bg-pounce-orange/10 text-pounce-orange' : 'text-gray-600'
                  }`}
                >
                  {section.label}
                </button>
              ))}
            </nav>
            <div class="p-4 border-t border-gray-100">
              <button
                type="submit"
                id="save-btn"
                class="w-full px-4 py-2 bg-charcoal text-white rounded-lg font-medium hover:bg-charcoal-light transition-colors text-sm"
              >
                Save Changes
              </button>
            </div>
          </div>
        </div>

        <!-- Settings Content -->
        <div class="lg:col-span-3 space-y-6">

          <!-- Business Identity -->
          <div id="section-business" class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <h2 class="text-lg font-semibold font-heading text-charcoal mb-4">Business Identity</h2>
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Business Name</label>
                <input type="text" name="business.name" value={business.name || ''} class="w-full px-4 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Tagline</label>
                <input type="text" name="business.tagline" value={business.tagline || ''} class="w-full px-4 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Website</label>
                <input type="url" name="business.website" value={business.website || ''} class="w-full px-4 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm" />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                <textarea name="business.description" rows={4} class="w-full px-4 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm">{business.description || ''}</textarea>
              </div>
            </div>
          </div>

          <!-- Tone & Voice -->
          <ToneSection
            style={(tone.style || 'professional') as string}
            instructions={(tone.instructions || '') as string}
            dos={toneDos}
            donts={toneDonts}
          />

          <!-- Knowledge Sources -->
          <KnowledgeSources links={knowledgeLinks} textEntries={knowledgeTexts} />

          <!-- Services & Pricing -->
          <ServicesSection services={services} />

          <!-- FAQ -->
          <FaqSection faq={faq.map(f => ({ question: f.question || '', answer: f.answer || '' }))} />

          <!-- Escalation Rules -->
          <EscalationSection triggers={escalationTriggers} notifyEmail={(escalation.notifyEmail || '') as string} />

          <!-- Booking -->
          <BookingSection
            url={booking.url || ''}
            ctaText={booking.ctaText || ''}
            timing={booking.timing || 'after_first_exchange'}
          />

          <!-- Integrations -->
          <IntegrationsSection
            llm={providers.llm || ''}
            email={providers.email || ''}
            fromEmail={providers.fromEmail || ''}
            model={providers.llmModel || ''}
            llmBaseUrl={providers.llmBaseUrl || ''}
            llmKeySet={llmKeySet}
            emailKeySet={emailKeySet}
          />

          <!-- Agent Mode -->
          <AgentMode
            enabled={(agent.enabled || false) as boolean}
            webhookUrl={(agent.webhookUrl || '') as string}
          />

        </div>
      </form>
    </div>
  </AdminLayout>

  <script>
    // Section navigation scroll
    document.querySelectorAll('[data-section-nav]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const sectionId = btn.getAttribute('data-section-nav');
        const section = document.getElementById(`section-${sectionId}`);
        if (section) {
          section.scrollIntoView({ behavior: 'smooth', block: 'start' });
        }
        document.querySelectorAll('[data-section-nav]').forEach((b) => {
          b.classList.remove('bg-pounce-orange/10', 'text-pounce-orange');
          b.classList.add('text-gray-600');
        });
        (btn as HTMLElement).classList.add('bg-pounce-orange/10', 'text-pounce-orange');
        btn.classList.remove('text-gray-600');
      });
    });

    // Form submission — collect data and PATCH
    const form = document.getElementById('settings-form') as HTMLFormElement;
    const saveBtn = document.getElementById('save-btn') as HTMLButtonElement;
    const saveStatus = document.getElementById('save-status') as HTMLDivElement;

    function showStatus(message: string, type: 'success' | 'error') {
      saveStatus.textContent = message;
      saveStatus.className = `mb-6 p-4 rounded-lg ${type === 'success' ? 'bg-green-50 text-green-700 border border-green-200' : 'bg-red-50 text-red-700 border border-red-200'}`;
      saveStatus.classList.remove('hidden');
      setTimeout(() => saveStatus.classList.add('hidden'), 5000);
    }

    function collectFormData(formEl: HTMLFormElement): Record<string, unknown> {
      const payload: Record<string, unknown> = {};
      const formData = new FormData(formEl);

      for (const [key, value] of formData.entries()) {
        // Convert checkboxes to booleans
        const boolValue = value === 'on' ? true : value;

        // Parse bracket notation: services[0].name → { services: [{ name: val }] }
        const match = key.match(/^(\w+)\[(\d+)\]\.(\w+)$/);
        if (match) {
          const [, arrName, indexStr, field] = match;
          const index = parseInt(indexStr!, 10);
          if (!payload[arrName!]) payload[arrName!] = [];
          const arr = payload[arrName!] as Array<Record<string, unknown>>;
          // Compact sparse arrays
          while (arr.length <= index) arr.push({});
          arr[index!][field!] = boolValue;
          continue;
        }

        // Parse dot notation: business.name → { business: { name: val } }
        if (key.includes('.') && !key.includes('[')) {
          const parts = key.split('.');
          let current: Record<string, unknown> = payload;
          for (let i = 0; i < parts.length - 1; i++) {
            if (!current[parts[i]!]) current[parts[i]!] = {};
            current = current[parts[i]!] as Record<string, unknown>;
          }
          current[parts[parts.length - 1]!] = boolValue;
          continue;
        }

        // Simple key
        payload[key] = boolValue;
      }

      return payload;
    }

    form?.addEventListener('submit', async (e) => {
      e.preventDefault();

      saveBtn.disabled = true;
      saveBtn.textContent = 'Saving...';

      const payload = collectFormData(form);

      try {
        const response = await fetch('/api/admin/config', {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          credentials: 'same-origin',
          body: JSON.stringify(payload),
        });

        if (response.ok) {
          showStatus('Settings saved successfully!', 'success');
        } else {
          const err = await response.json().catch(() => ({ error: 'Save failed' }));
          showStatus(err.error || 'Failed to save settings.', 'error');
        }
      } catch {
        showStatus('Network error. Please try again.', 'error');
      } finally {
        saveBtn.disabled = false;
        saveBtn.textContent = 'Save Changes';
      }
    });
  </script>
</AdminPage>