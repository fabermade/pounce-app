---
import AdminPage from '../../layouts/AdminPage.astro';
import AdminLayout from '../../components/admin/AdminLayout';

// Fetch config from API
let configData: {
  config: Record<string, unknown>;
} = { config: {} };

let error: string | null = null;

try {
  const response = await fetch(new URL('/api/admin/config', Astro.url.origin));
  if (response.ok) {
    configData = await response.json();
  } else {
    const errData = await response.json().catch(() => ({ error: 'Failed to fetch config' }));
    error = errData.error || `Error ${response.status}`;
  }
} catch (e) {
  error = 'Network error. Please try again.';
}

const config = configData.config;

const settingsSections = [
  { id: 'business', label: 'Business Identity' },
  { id: 'tone', label: 'Tone & Voice' },
  { id: 'knowledge', label: 'Knowledge Sources' },
  { id: 'services', label: 'Services & Pricing' },
  { id: 'faq', label: 'FAQ' },
  { id: 'escalation', label: 'Escalation Rules' },
  { id: 'booking', label: 'Booking' },
  { id: 'integrations', label: 'Integrations' },
  { id: 'agent', label: 'Agent Mode' },
];

// Type-safe config accessors
const business = (config.business || {}) as Record<string, string>;
const tone = (config.tone || {}) as Record<string, unknown>;
const services = (config.services || []) as Array<Record<string, string>>;
const faq = (config.faq || []) as Array<Record<string, string>>;
const escalation = (config.escalation || {}) as Record<string, unknown>;
const booking = (config.booking || {}) as Record<string, string>;
const providers = (config.providers || {}) as Record<string, string>;

const toneDos = (tone.dos || []) as string[];
const toneDonts = (tone.donts || []) as string[];
const escalationTriggers = (escalation.triggerPhrases || []) as string[];
---

<AdminPage title="Settings" currentPath="/admin/settings">
  <AdminLayout currentPath="/admin/settings">
    <div class="p-8">
      <!-- Header -->
      <div class="mb-8">
        <h1 class="text-3xl font-bold font-heading text-charcoal mb-2">Settings</h1>
        <p class="text-gray-500">Configure your AI lead response agent</p>
      </div>

      <!-- Error State -->
      {error && (
        <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg">
          <p class="text-sm text-red-600">{error}</p>
        </div>
      )}

      <!-- BOLT: Need PATCH /api/admin/config for saves -->

      <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
        <!-- Settings Navigation -->
        <div class="lg:col-span-1">
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <nav class="divide-y divide-gray-100">
              {settingsSections.map((section, index) => (
                <button
                  class={`w-full text-left px-4 py-3 text-sm font-medium transition-colors hover:bg-gray-50 ${
                    index === 0 ? 'bg-pounce-orange/10 text-pounce-orange' : 'text-gray-600'
                  }`}
                >
                  {section.label}
                </button>
              ))}
            </nav>
          </div>
        </div>

        <!-- Settings Content -->
        <div class="lg:col-span-3 space-y-6">
          <!-- Business Identity -->
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <h2 class="text-lg font-semibold font-heading text-charcoal mb-4">Business Identity</h2>
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Business Name</label>
                <input
                  type="text"
                  name="business.name"
                  value={business.name || ''}
                  class="w-full px-4 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Tagline</label>
                <input
                  type="text"
                  name="business.tagline"
                  value={business.tagline || ''}
                  class="w-full px-4 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Website</label>
                <input
                  type="url"
                  name="business.website"
                  value={business.website || ''}
                  class="w-full px-4 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                <textarea
                  name="business.description"
                  rows={4}
                  class="w-full px-4 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
                >{business.description || ''}</textarea>
              </div>
            </div>
          </div>

          <!-- Tone & Voice -->
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <h2 class="text-lg font-semibold font-heading text-charcoal mb-4">Tone & Voice</h2>
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Style Preset</label>
                <select
                  name="tone.style"
                  class="w-full px-4 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
                >
                  <option value="professional" selected={tone.style === 'professional'}>Professional</option>
                  <option value="friendly" selected={tone.style === 'friendly'}>Friendly</option>
                  <option value="casual" selected={tone.style === 'casual'}>Casual</option>
                  <option value="formal" selected={tone.style === 'formal'}>Formal</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Custom Instructions</label>
                <textarea
                  name="tone.instructions"
                  rows={3}
                  class="w-full px-4 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
                >{(tone.instructions || '') as string}</textarea>
              </div>
              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-2">Dos</label>
                  <div class="space-y-2">
                    {toneDos.length > 0 ? toneDos.map((item) => (
                      <div class="flex items-center gap-2">
                        <svg class="w-4 h-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        <span class="text-sm text-gray-600">{item}</span>
                      </div>
                    )) : (
                      <p class="text-sm text-gray-400">No dos configured.</p>
                    )}
                  </div>
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-2">Don'ts</label>
                  <div class="space-y-2">
                    {toneDonts.length > 0 ? toneDonts.map((item) => (
                      <div class="flex items-center gap-2">
                        <svg class="w-4 h-4 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                        <span class="text-sm text-gray-600">{item}</span>
                      </div>
                    )) : (
                      <p class="text-sm text-gray-400">No don'ts configured.</p>
                    )}
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Services -->
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-lg font-semibold font-heading text-charcoal">Services & Pricing</h2>
              <button class="px-4 py-2 bg-pounce-orange text-white rounded-lg text-sm font-medium hover:bg-pounce-orange-dark transition-colors">
                + Add Service
              </button>
            </div>
            {services.length === 0 ? (
              <p class="text-sm text-gray-400">No services configured.</p>
            ) : (
              <div class="space-y-4">
                {services.map((service) => (
                  <div class="p-4 border border-gray-200 rounded-lg">
                    <div class="flex items-center justify-between mb-2">
                      <input
                        type="text"
                        value={service.name || ''}
                        class="font-medium text-charcoal bg-transparent border-none focus:outline-none"
                      />
                      <button class="text-gray-400 hover:text-red-500 transition-colors">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                        </svg>
                      </button>
                    </div>
                    <input
                      type="text"
                      value={service.description || ''}
                      class="w-full text-sm text-gray-600 bg-transparent border-none focus:outline-none mb-2"
                    />
                    <input
                      type="text"
                      value={service.price || ''}
                      class="text-sm text-pounce-orange font-medium bg-transparent border-none focus:outline-none"
                    />
                  </div>
                ))}
              </div>
            )}
          </div>

          <!-- Escalation -->
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <h2 class="text-lg font-semibold font-heading text-charcoal mb-4">Escalation Rules</h2>
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Trigger Phrases</label>
                <div class="flex flex-wrap gap-2">
                  {escalationTriggers.map((phrase) => (
                    <span class="px-2 py-1 bg-red-50 text-red-700 rounded text-xs font-medium">{phrase}</span>
                  ))}
                </div>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Notify Email</label>
                <input
                  type="email"
                  value={(escalation.notifyEmail || '') as string}
                  class="w-full px-4 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
                />
              </div>
            </div>
          </div>

          <!-- Booking -->
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <h2 class="text-lg font-semibold font-heading text-charcoal mb-4">Booking</h2>
            <div class="space-y-4 max-w-lg">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Booking Provider</label>
                <select
                  name="booking.provider"
                  class="w-full px-4 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
                >
                  <option value="calcom" selected={booking.provider === 'calcom'}>Cal.com</option>
                  <option value="calendly" selected={booking.provider === 'calendly'}>Calendly</option>
                  <option value="" selected={!booking.provider}>None</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Booking URL</label>
                <input
                  type="url"
                  name="booking.url"
                  value={booking.url || ''}
                  placeholder="https://cal.com/your-name"
                  class="w-full px-4 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">CTA Text</label>
                <input
                  type="text"
                  name="booking.cta"
                  value={booking.cta || ''}
                  placeholder="Book a call"
                  class="w-full px-4 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">When to Offer Booking</label>
                <select
                  name="booking.timing"
                  class="w-full px-4 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
                >
                  <option value="immediately" selected={booking.timing === 'immediately'}>Immediately</option>
                  <option value="after_first_exchange" selected={booking.timing === 'after_first_exchange'}>After first exchange</option>
                  <option value="after_second_exchange" selected={booking.timing === 'after_second_exchange'}>After second exchange</option>
                  <option value="manual" selected={booking.timing === 'manual'}>Manual only</option>
                </select>
              </div>
              <div class="mt-4 p-4 bg-gray-50 rounded-lg border border-gray-200">
                <label class="block text-xs font-medium text-gray-500 uppercase tracking-wider mb-2">Webhook URL</label>
                <div class="flex items-center gap-2">
                  <input
                    type="text"
                    readonly
                    value={booking.provider ? `https://www.pouncefirst.com/api/webhook/booking?provider=${booking.provider}` : 'Select a provider to see webhook URL'}
                    class="flex-1 px-3 py-2 bg-white border border-gray-200 rounded-lg text-xs font-mono text-gray-600"
                  />
                  <button class="px-3 py-2 bg-charcoal text-white rounded-lg text-xs font-medium hover:bg-charcoal-light transition-colors">Copy</button>
                </div>
                <p class="text-xs text-gray-400 mt-2">Paste this into your booking provider's webhook settings.</p>
              </div>
            </div>
          </div>

          <!-- Providers -->
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <h2 class="text-lg font-semibold font-heading text-charcoal mb-4">Providers</h2>
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">LLM Provider</label>
                <select class="w-full px-4 py-2 rounded-lg border border-gray-200 text-sm">
                  <option value="openai" selected={providers.llm === 'openai'}>OpenAI</option>
                  <option value="anthropic" selected={providers.llm === 'anthropic'}>Anthropic</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Email Provider</label>
                <select class="w-full px-4 py-2 rounded-lg border border-gray-200 text-sm">
                  <option value="resend" selected={providers.email === 'resend'}>Resend</option>
                  <option value="sendgrid" selected={providers.email === 'sendgrid'}>SendGrid</option>
                  <option value="mailgun" selected={providers.email === 'mailgun'}>Mailgun</option>
                </select>
              </div>
            </div>
          </div>

          <!-- Save Button -->
          <div class="flex justify-end">
            <button class="px-6 py-3 bg-charcoal text-white rounded-lg font-medium hover:bg-charcoal-light transition-colors">
              Save Changes
            </button>
          </div>
        </div>
      </div>
    </div>
  </AdminLayout>
</AdminPage>