---
/**
 * Public Booking Page — /book
 *
 * Renders a Cal.com or Calendly embed based on business config.
 * Falls back to a simple "Book a Call" link if no embed is configured.
 */

import { db, businessConfig } from '@/lib/db/index.js';
import { eq } from 'drizzle-orm';

// Load booking config
const [bookingConfig] = await db
  .select()
  .from(businessConfig)
  .where(eq(businessConfig.key, 'booking'))
  .limit(1);

const booking = (bookingConfig?.value ?? {}) as Record<string, string>;

const bookingUrl = booking.url ?? '';
const bookingProvider = booking.provider ?? (bookingUrl.includes('calendly') ? 'calendly' : 'calcom');
const bookingCta = booking.cta ?? 'Book a Call';

// Also load business info for branding
const [bizConfig] = await db
  .select()
  .from(businessConfig)
  .where(eq(businessConfig.key, 'business'))
  .limit(1);

const business = (bizConfig?.value ?? {}) as Record<string, string>;
const businessName = business.name || 'Us';
const businessTagline = business.tagline || '';
const isCalendly = bookingProvider === 'calendly';
const isCalcom = bookingProvider === 'calcom' && bookingUrl;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Book a Call — {businessName}</title>
  <style>
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
      background: #fafafa;
      color: #1a1a2e;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
    }
    .header {
      background: #fff;
      border-bottom: 1px solid #e5e7eb;
      padding: 16px 24px;
      display: flex;
      align-items: center;
      gap: 12px;
    }
    .header h1 {
      font-size: 18px;
      font-weight: 600;
    }
    .header .powered {
      margin-left: auto;
      font-size: 12px;
      color: #9ca3af;
    }
    .booking-container {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 40px 20px;
    }
    .no-booking {
      text-align: center;
      max-width: 400px;
    }
    .no-booking h2 {
      font-size: 24px;
      margin-bottom: 12px;
    }
    .no-booking p {
      color: #6b7280;
      margin-bottom: 24px;
    }
    .no-booking a {
      display: inline-block;
      background: #FF6B35;
      color: #fff;
      padding: 12px 24px;
      border-radius: 8px;
      text-decoration: none;
      font-weight: 600;
    }
    .no-booking a:hover {
      background: #e55a2b;
    }
    #calcom-embed {
      width: 100%;
      max-width: 800px;
      min-height: 600px;
    }
    .calendly-inline-widget {
      width: 100%;
      min-width: 320px;
      height: 700px;
    }
  </style>
</head>
<body>
  <div class="header">
    <h1>{businessName}</h1>
    {businessTagline && <span class="powered">{businessTagline}</span>}
  </div>

  <div class="booking-container">
    {bookingUrl ? (
      isCalendly ? (
        <div class="calendly-inline-widget" data-url={bookingUrl}></div>
      ) : isCalcom ? (
        <div id="calcom-embed"></div>
      ) : (
        <div class="no-booking">
          <h2>📅 {bookingCta}</h2>
          <p>Schedule a time that works for you.</p>
          <a href={bookingUrl} target="_blank" rel="noopener noreferrer">{bookingCta}</a>
        </div>
      )
    ) : (
      <div class="no-booking">
        <h2>📅 {bookingCta}</h2>
        <p>Schedule a time that works for you.</p>
        <p style="color: #9ca3af; font-size: 14px;">No booking system configured yet. Please contact us directly.</p>
      </div>
    )}
  </div>

  {isCalendly && bookingUrl && (
    <script is:inline src="https://assets.calendly.com/assets/external/widget.js" async></script>
  )}

  {isCalcom && bookingUrl && (
    <span id="cal-link-data" data-link={bookingUrl.replace('https://cal.com/', '').replace('https://app.cal.com/', '').replace(/\/+$/, '')} style="display:none"></span>
    <script is:inline src="https://app.cal.com/embed/embed.js" async></script>
  )}

  {isCalcom && bookingUrl && (
    <script is:inline>
      function initCal() {
        if (!window.Cal) {
          setTimeout(initCal, 100);
          return;
        }
        var el = document.getElementById('cal-link-data');
        var calLink = el ? el.getAttribute('data-link') : '';
        var container = document.getElementById('calcom-embed');
        if (container && calLink) {
          window.Cal('inline', {
            elementOrSelector: '#calcom-embed',
            calLink: calLink,
            config: { layout: 'month_view' }
          });
          window.Cal('ui', {
            styles: { branding: { brandColor: '#FF6B35' } }
          });
        }
      }

      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initCal);
      } else {
        initCal();
      }
    </script>
  )}
</body>
</html>