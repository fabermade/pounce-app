const session = Astro.locals.session;
const currentUser = session ? { name: session.name || null, email: session.email } : null;
---
import AdminPage from '../../../layouts/AdminPage.astro';
import AdminLayout from '../../../components/admin/AdminLayout';

const { id } = Astro.params;
let form: any = null;
let error: string | null = null;

try {
  const res = await fetch(`${Astro.url.origin}/api/admin/forms/${id}`, {
    headers: { 'Cookie': Astro.request.headers.get('cookie') || '' }
  });
  if (res.ok) {
    const data = await res.json();
    form = data.form;
  } else {
    error = 'Failed to load form';
  }
} catch (e) {
  error = 'Failed to load form';
}

const APP_URL = import.meta.env.APP_URL || process.env.APP_URL || Astro.url.origin;
const session = Astro.locals.session;
const currentUser = session ? { name: session.name || null, email: session.email } : null;
---

<AdminPage title="Edit Form" currentPath="/admin/forms">
<AdminLayout currentPath="/admin/forms" currentUser={currentUser}>
  <div class="p-8 max-w-6xl mx-auto">
    <div class="mb-8">
      <a href="/admin/forms" class="text-sm text-gray-500 hover:text-charcoal transition-colors mb-2 inline-block">&larr; Back to forms</a>
      <h1 class="text-2xl font-bold font-heading text-charcoal">{form?.name || 'Edit Form'}</h1>
      <p class="text-sm text-gray-500 mt-1">Update fields, settings, and embed code</p>
    </div>

    {error && (
      <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg">
        <p class="text-sm text-red-600">{error}</p>
      </div>
    )}

    {form && (
      <>
        <!-- Hidden data for client script -->
        <script type="application/json" id="form-data" set:html={JSON.stringify(form)} is:inline></script>

        <!-- Analytics Section -->
        <div id="analytics-section" class="mb-6">
          <div class="grid grid-cols-3 gap-4 mb-6">
            <div class="bg-white rounded-xl border border-gray-200 p-4">
              <p class="text-xs text-gray-500 mb-1">Views</p>
              <p id="stat-views" class="text-2xl font-bold font-heading text-charcoal">-</p>
            </div>
            <div class="bg-white rounded-xl border border-gray-200 p-4">
              <p class="text-xs text-gray-500 mb-1">Submissions</p>
              <p id="stat-submissions" class="text-2xl font-bold font-heading text-charcoal">-</p>
            </div>
            <div class="bg-white rounded-xl border border-gray-200 p-4">
              <p class="text-xs text-gray-500 mb-1">Conversion Rate</p>
              <p id="stat-rate" class="text-2xl font-bold font-heading text-charcoal">-</p>
            </div>
          </div>

          <div class="bg-white rounded-xl border border-gray-200 p-6">
            <h2 class="text-lg font-bold font-heading text-charcoal mb-4">Recent Submissions</h2>
            <div id="submissions-table" class="overflow-x-auto">
              <p class="text-sm text-gray-400 text-center py-8">Loading...</p>
            </div>
          </div>
        </div>

        <!-- Embed Code Card with Modal Trigger -->
        <div class="bg-white rounded-xl border border-gray-200 p-6 mb-6">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h2 class="text-lg font-bold font-heading text-charcoal">Embed Code</h2>
              <p class="text-sm text-gray-500">Paste this script on any page to embed the form</p>
            </div>
            <span class={`inline-flex px-2 py-0.5 rounded-full text-xs font-medium ${
              form.active ? 'bg-green-50 text-green-700' : 'bg-gray-100 text-gray-500'
            }`}>
              {form.active ? 'Active' : 'Inactive'}
            </span>
          </div>
          <div class="flex items-center gap-2">
            <input
              type="text"
              readonly
              value={`<script src="${APP_URL}/api/f/${form.slug}/embed.js"></script>`}
              id="embed-code"
              class="flex-1 px-4 py-2.5 bg-gray-50 border border-gray-200 rounded-lg text-sm font-mono text-gray-600"
            />
            <button id="open-embed-modal" class="px-4 py-2.5 bg-charcoal text-white rounded-lg text-sm font-medium hover:bg-charcoal-light transition-colors">Get Embed Code</button>
          </div>
          <p class="text-xs text-gray-400 mt-2">Public URL: <a href={`/f/${form.slug}`} class="text-pounce-orange hover:underline">${APP_URL}/f/{form.slug}</a></p>
        </div>

        <!-- Embed Modal -->
        <div id="embed-modal" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center">
          <div class="bg-white rounded-xl shadow-lg border border-gray-200 w-full max-w-lg mx-4 p-6">
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-lg font-bold font-heading text-charcoal">Embed Code</h2>
              <button id="close-embed-modal" class="text-gray-400 hover:text-charcoal">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path></svg>
              </button>
            </div>
            <p class="text-sm text-gray-500 mb-4">Paste this script tag on any page to embed the form.</p>
            <div class="bg-gray-50 border border-gray-200 rounded-lg p-4 mb-4">
              <code class="text-sm font-mono text-gray-700 break-all" id="embed-modal-code">&lt;script src="${APP_URL}/api/f/{form.slug}/embed.js"&gt;&lt;/script&gt;</code>
            </div>
            <div class="flex items-center gap-3">
              <button id="copy-embed-modal" class="px-4 py-2 bg-charcoal text-white rounded-lg text-sm font-medium hover:bg-charcoal-light transition-colors">Copy to Clipboard</button>
              <a href={`/f/${form.slug}`} target="_blank" class="text-sm text-pounce-orange hover:underline">Preview Form &rarr;</a>
            </div>
          </div>
        </div>

        <!-- Iframe Preview -->
        <div class="bg-white rounded-xl border border-gray-200 p-6 mb-6">
          <div class="flex items-center justify-between mb-4">
            <div>
              <h2 class="text-lg font-bold font-heading text-charcoal">Live Preview</h2>
              <p class="text-sm text-gray-500">This is how the form looks to visitors</p>
            </div>
            <a href={`/f/${form.slug}`} target="_blank" class="text-sm text-pounce-orange hover:underline">Open in new tab &rarr;</a>
          </div>
          <div class="bg-gray-50 rounded-lg border border-gray-200 overflow-hidden">
            <iframe
              src={`/f/${form.slug}`}
              class="w-full h-[400px]"
              title={`Preview of ${form.name}`}
              sandbox="allow-forms allow-scripts"
            />
          </div>
        </div>

        <!-- Edit Form (same structure as new, pre-filled) -->
        <div id="error-banner" class="hidden mb-6 p-4 bg-red-50 border border-red-200 rounded-lg">
          <p class="text-sm text-red-600"></p>
        </div>

        <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
          <div class="lg:col-span-2 space-y-6">
            <div class="bg-white rounded-xl border border-gray-200 p-6">
              <h2 class="text-lg font-bold font-heading text-charcoal mb-4">Form Details</h2>
              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Name</label>
                  <input type="text" id="form-name" value={form.name} class="w-full px-4 py-2.5 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm" />
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Slug</label>
                  <input type="text" id="form-slug" value={form.slug} readonly class="w-full px-4 py-2.5 rounded-lg border border-gray-200 bg-gray-50 text-sm font-mono text-gray-500" />
                </div>
              </div>
            </div>

            <div class="bg-white rounded-xl border border-gray-200 p-6">
              <div class="flex items-center justify-between mb-4">
                <h2 class="text-lg font-bold font-heading text-charcoal">Fields</h2>
                <div class="flex gap-2">
                  <button id="add-text" class="px-3 py-1.5 text-xs bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-colors">+ Text</button>
                  <button id="add-email" class="px-3 py-1.5 text-xs bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-colors">+ Email</button>
                  <button id="add-textarea" class="px-3 py-1.5 text-xs bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-colors">+ Textarea</button>
                  <button id="add-tel" class="px-3 py-1.5 text-xs bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-colors">+ Phone</button>
                  <button id="add-select" class="px-3 py-1.5 text-xs bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-colors">+ Select</button>
                  <button id="add-checkbox" class="px-3 py-1.5 text-xs bg-gray-100 text-gray-700 rounded-lg hover:bg-gray-200 transition-colors">+ Checkbox</button>
                </div>
              </div>

              <div id="fields-list" class="space-y-3"></div>
              <p id="no-fields" class="text-sm text-gray-400 text-center py-8" style="display: none;">No fields yet. Add one above.</p>
            </div>

            <div class="bg-white rounded-xl border border-gray-200 p-6">
              <h2 class="text-lg font-bold font-heading text-charcoal mb-4">Settings</h2>
              <div class="space-y-4">
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Submit Message</label>
                  <input type="text" id="submit-message" value={form.submitMessage || ''} class="w-full px-4 py-2.5 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm" />
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-1">Redirect URL (optional)</label>
                  <input type="text" id="redirect-url" value={form.redirectUrl || ''} class="w-full px-4 py-2.5 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm" />
                </div>
                <div class="flex items-center gap-3">
                  <input type="checkbox" id="form-active" checked={form.active} class="w-4 h-4 rounded border-gray-300 text-pounce-orange focus:ring-pounce-orange" />
                  <label for="form-active" class="text-sm text-gray-700">Active</label>
                </div>
              </div>
            </div>

            <div class="flex items-center justify-end gap-3">
              <button id="delete-form-btn" class="px-4 py-2.5 text-sm text-red-600 hover:text-red-700 transition-colors">Delete Form</button>
              <button id="save-btn" class="px-6 py-2.5 bg-charcoal text-white rounded-lg text-sm font-medium hover:bg-charcoal-light transition-colors">Save Changes</button>
            </div>
          </div>

          <div class="lg:col-span-1">
            <div class="bg-white rounded-xl border border-gray-200 p-6 sticky top-6">
              <h2 class="text-lg font-bold font-heading text-charcoal mb-4">Live Preview</h2>
              <div id="preview-container" class="space-y-4"></div>
            </div>
          </div>
        </div>
      </>
    )}
  </div>

  <!-- Delete Confirmation -->
  <div id="delete-dialog" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center">
    <div class="bg-white rounded-xl shadow-lg border border-gray-200 w-full max-w-sm mx-4 p-6">
      <h2 class="text-lg font-bold font-heading text-charcoal mb-1">Delete Form</h2>
      <p class="text-sm text-gray-500 mb-5">Are you sure? This will remove the form and all submissions. This cannot be undone.</p>
      <div class="flex items-center justify-end gap-3">
        <button id="delete-cancel" class="px-4 py-2 text-sm text-gray-600 hover:text-charcoal transition-colors">Cancel</button>
        <button id="delete-confirm" class="px-4 py-2 bg-red-600 text-white rounded-lg text-sm font-medium hover:bg-red-700 transition-colors">Delete</button>
      </div>
    </div>
  </div>
</AdminLayout>
</AdminPage>

<script>
  const formDataEl = document.getElementById('form-data');
  const initialForm = formDataEl ? JSON.parse(formDataEl.textContent || '{}') : {};
  if (!formDataEl) {
    console.warn('Form data element not found, form editor disabled');
  }

  interface FormField {
    id: string;
    name: string;
    type: string;
    label: string;
    required: boolean;
    placeholder: string;
    options?: string[];
  }

  let fields: FormField[] = (initialForm?.fields || []).map((f: any, i: number) => ({
    id: 'field_' + i + '_' + Math.random().toString(36).substring(2, 5),
    name: f.name,
    type: f.type,
    label: f.label,
    required: f.required || false,
    placeholder: f.placeholder || '',
    options: f.options || undefined,
  }));

  function generateId(): string {
    return 'field_' + Math.random().toString(36).substring(2, 9);
  }

  function addField(type: string) {
    const field: FormField = {
      id: generateId(),
      name: `field_${fields.length + 1}`,
      type,
      label: type === 'text' ? 'Text Field' :
             type === 'email' ? 'Email Address' :
             type === 'textarea' ? 'Message' :
             type === 'tel' ? 'Phone Number' :
             type === 'select' ? 'Select Option' :
             'Checkbox',
      required: false,
      placeholder: type === 'email' ? 'you@company.com' :
                   type === 'tel' ? '(555) 123-4567' :
                   'Enter text...',
      options: type === 'select' ? ['Option 1', 'Option 2', 'Option 3'] : undefined,
    };
    fields.push(field);
    render();
  }

  function removeField(id: string) {
    fields = fields.filter(f => f.id !== id);
    render();
  }

  function updateField(id: string, key: string, value: any, shouldRender = true) {
    const field = fields.find(f => f.id === id);
    if (field) {
      (field as any)[key] = value;
      if (shouldRender) render();
    }
  }

  function moveField(id: string, direction: string) {
    const idx = fields.findIndex(f => f.id === id);
    if (idx === -1) return;
    if (direction === 'up' && idx > 0) {
      const a = fields[idx]!, b = fields[idx - 1]!;
      fields[idx] = b;
      fields[idx - 1] = a;
    } else if (direction === 'down' && idx < fields.length - 1) {
      const a = fields[idx]!, b = fields[idx + 1]!;
      fields[idx] = b;
      fields[idx + 1] = a;
    }
    render();
  }

  function escapeHtml(str: string): string {
    const div = document.createElement('div');
    div.textContent = str;
    return div.innerHTML;
  }

  function renderFieldEditor(field: FormField): string {
    const optionsHtml = field.options ? field.options.map((opt: string, i: number) => `
      <div class="flex items-center gap-2">
        <input type="text" value="${escapeHtml(opt)}" data-field="${field.id}" data-opt-idx="${i}" class="option-input flex-1 px-2 py-1 text-xs border border-gray-200 rounded" />
        <button data-field="${field.id}" data-remove-opt="${i}" class="text-red-400 hover:text-red-600 text-xs">&times;</button>
      </div>
    `).join('') : '';

    return `
      <div class="border border-gray-200 rounded-lg p-4 bg-gray-50/50" data-field-id="${field.id}">
        <div class="flex items-center justify-between mb-3">
          <div class="flex items-center gap-2">
            <span class="text-xs font-medium text-gray-500 uppercase">${escapeHtml(field.type)}</span>
            <input type="text" value="${escapeHtml(field.label)}" data-field="${field.id}" data-key="label" class="font-medium text-sm bg-transparent border-b border-transparent hover:border-gray-300 focus:border-pounce-orange focus:outline-none px-1" />
          </div>
          <div class="flex items-center gap-1">
            <button data-move="${field.id}" data-dir="up" class="p-1 text-gray-400 hover:text-charcoal" title="Move up">&uarr;</button>
            <button data-move="${field.id}" data-dir="down" class="p-1 text-gray-400 hover:text-charcoal" title="Move down">&darr;</button>
            <button data-remove="${field.id}" class="p-1 text-red-400 hover:text-red-600" title="Remove">&times;</button>
          </div>
        </div>
        <div class="grid grid-cols-2 gap-3">
          <div>
            <label class="text-xs text-gray-500">Name</label>
            <input type="text" value="${escapeHtml(field.name)}" data-field="${field.id}" data-key="name" class="w-full px-2 py-1 text-xs border border-gray-200 rounded" />
          </div>
          <div>
            <label class="text-xs text-gray-500">Placeholder</label>
            <input type="text" value="${escapeHtml(field.placeholder || '')}" data-field="${field.id}" data-key="placeholder" class="w-full px-2 py-1 text-xs border border-gray-200 rounded" />
          </div>
        </div>
        <div class="flex items-center gap-2 mt-3">
          <input type="checkbox" ${field.required ? 'checked' : ''} data-field="${field.id}" data-key="required" id="req-${field.id}" class="w-3.5 h-3.5" />
          <label for="req-${field.id}" class="text-xs text-gray-600">Required</label>
        </div>
        ${field.type === 'select' ? `
          <div class="mt-3">
            <label class="text-xs text-gray-500 mb-1 block">Options</label>
            <div class="space-y-1">${optionsHtml}</div>
            <button data-add-opt="${field.id}" class="mt-2 text-xs text-pounce-orange hover:underline">+ Add option</button>
          </div>
        ` : ''}
      </div>
    `;
  }

  function renderPreviewField(field: FormField): string {
    const required = field.required ? ' *' : '';
    const esc = escapeHtml;
    const commonClasses = 'w-full px-4 py-2.5 rounded-lg border border-gray-200 text-sm focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange';

    switch (field.type) {
      case 'textarea':
        return `
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">${esc(field.label)}${required}</label>
            <textarea placeholder="${esc(field.placeholder || '')}" ${field.required ? 'required' : ''} class="${commonClasses} min-h-[100px] resize-y"></textarea>
          </div>
        `;
      case 'select':
        return `
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">${esc(field.label)}${required}</label>
            <select ${field.required ? 'required' : ''} class="${commonClasses} bg-white">
              <option value="">Select...</option>
              ${(field.options || []).map(o => `<option>${esc(o)}</option>`).join('')}
            </select>
          </div>
        `;
      case 'checkbox':
        return `
          <div class="flex items-center gap-2">
            <input type="checkbox" ${field.required ? 'required' : ''} class="w-4 h-4 rounded border-gray-300 text-pounce-orange focus:ring-pounce-orange" />
            <label class="text-sm text-gray-700">${esc(field.label)}${required}</label>
          </div>
        `;
      default:
        return `
          <div>
            <label class="block text-sm font-medium text-gray-700 mb-1">${esc(field.label)}${required}</label>
            <input type="${esc(field.type)}" placeholder="${esc(field.placeholder || '')}" ${field.required ? 'required' : ''} class="${commonClasses}" />
          </div>
        `;
    }
  }

  function updatePreview() {
    const preview = document.getElementById('preview-container');
    if (fields.length === 0) {
      if (preview) preview.innerHTML = '<p class="text-sm text-gray-400 text-center py-8">Add fields to see preview</p>';
      return;
    }
    if (preview) preview.innerHTML = fields.map(renderPreviewField).join('') + `
      <button class="w-full py-2.5 bg-charcoal text-white rounded-lg text-sm font-medium">Submit</button>
    `;
  }

  function render() {
    const list = document.getElementById('fields-list');
    const noFields = document.getElementById('no-fields');
    const preview = document.getElementById('preview-container');

    if (fields.length === 0) {
      if (list) list.innerHTML = '';
      if (noFields) noFields.style.display = 'block';
      if (preview) preview.innerHTML = '<p class="text-sm text-gray-400 text-center py-8">Add fields to see preview</p>';
      return;
    }

    if (noFields) noFields.style.display = 'none';
    if (list) list.innerHTML = fields.map(renderFieldEditor).join('');
    if (preview) preview.innerHTML = fields.map(renderPreviewField).join('') + `
      <button class="w-full py-2.5 bg-charcoal text-white rounded-lg text-sm font-medium">Submit</button>
    `;

    document.querySelectorAll('[data-field]').forEach((el) => {
      const input = el as HTMLInputElement;
      const fieldId = input.dataset.field;
      const key = input.dataset.key;
      if (key === 'required') {
        input.addEventListener('change', (e) => {
          updateField(fieldId!, 'required', (e.target as HTMLInputElement).checked);
        });
      } else {
        // Text inputs: update model only, don't re-render editor (preserves focus)
        // But do update the preview panel
        input.addEventListener('input', (e) => {
          updateField(fieldId!, key!, (e.target as HTMLInputElement).value, false);
          updatePreview();
        });
      }
    });

    document.querySelectorAll('[data-remove]').forEach((el) => {
      const btn = el as HTMLElement;
      btn.addEventListener('click', () => removeField(btn.dataset.remove!));
    });

    document.querySelectorAll('[data-move]').forEach((el) => {
      const btn = el as HTMLElement;
      btn.addEventListener('click', () => moveField(btn.dataset.move!, btn.dataset.dir!));
    });

    document.querySelectorAll('[data-add-opt]').forEach((el) => {
      const btn = el as HTMLElement;
      btn.addEventListener('click', () => {
        const field = fields.find((f: any) => f.id === btn.dataset.addOpt);
        if (field && field.options) {
          field.options.push(`Option ${field.options.length + 1}`);
          render();
        }
      });
    });

    document.querySelectorAll('[data-remove-opt]').forEach((el) => {
      const btn = el as HTMLElement;
      btn.addEventListener('click', () => {
        const field = fields.find((f: any) => f.id === btn.dataset.field);
        if (field && field.options) {
          field.options.splice(parseInt(btn.dataset.removeOpt!, 10), 1);
          render();
        }
      });
    });

    document.querySelectorAll('.option-input').forEach((el) => {
      const input = el as HTMLInputElement;
      input.addEventListener('input', () => {
        const field = fields.find((f: any) => f.id === input.dataset.field);
        if (field && field.options) {
          field.options[parseInt(input.dataset.optIdx!, 10)] = input.value;
          // Don't re-render editor — just update preview
          updatePreview();
        }
      });
    });
  }

  // Init
  render();

  // Add field buttons
  document.getElementById('add-text')?.addEventListener('click', () => addField('text'));
  document.getElementById('add-email')?.addEventListener('click', () => addField('email'));
  document.getElementById('add-textarea')?.addEventListener('click', () => addField('textarea'));
  document.getElementById('add-tel')?.addEventListener('click', () => addField('tel'));
  document.getElementById('add-select')?.addEventListener('click', () => addField('select'));
  document.getElementById('add-checkbox')?.addEventListener('click', () => addField('checkbox'));

  // Analytics: fetch stats
  async function loadAnalytics() {
    try {
      const res = await fetch(`/api/admin/forms/${initialForm.id}/stats`);
      const data = await res.json();
      if (res.ok && data.stats) {
        const viewsEl = document.getElementById('stat-views');
        const subsEl = document.getElementById('stat-submissions');
        const rateEl = document.getElementById('stat-rate');
        const tableEl = document.getElementById('submissions-table');

        if (viewsEl) viewsEl.textContent = String(data.stats.views || 0);
        if (subsEl) subsEl.textContent = String(data.stats.submissions || 0);
        const rate = data.stats.views > 0 ? Math.round((data.stats.submissions / data.stats.views) * 100) : 0;
        if (rateEl) rateEl.textContent = rate + '%';

        if (tableEl) {
          const submissions = data.recentSubmissions || [];
          if (submissions.length === 0) {
            tableEl.innerHTML = '<p class="text-sm text-gray-400 text-center py-8">No submissions yet</p>';
          } else {
            tableEl.innerHTML = '<table class="w-full text-sm"><thead><tr class="border-b border-gray-100"><th class="text-left py-2 px-3 text-gray-500 font-medium">Date</th><th class="text-left py-2 px-3 text-gray-500 font-medium">Data</th></tr></thead><tbody class="divide-y divide-gray-50">' +
              submissions.map((s: any) => `
                <tr class="hover:bg-gray-50">
                  <td class="py-2 px-3 text-gray-600 whitespace-nowrap">${new Date(s.createdAt).toLocaleDateString()}</td>
                  <td class="py-2 px-3 text-gray-600 truncate max-w-[300px]">${escapeHtml(JSON.stringify(s.data || {}))}</td>
                </tr>
              `).join('') +
              '</tbody></table>';
          }
        }
      }
    } catch (err) {
      // Silently fail analytics
    }
  }
  loadAnalytics();

  // Embed modal handlers
  const embedModal = document.getElementById('embed-modal');
  const openEmbedModalBtn = document.getElementById('open-embed-modal');
  const closeEmbedModalBtn = document.getElementById('close-embed-modal');
  const copyEmbedModalBtn = document.getElementById('copy-embed-modal');

  if (openEmbedModalBtn && embedModal) {
    openEmbedModalBtn.addEventListener('click', () => {
      embedModal.classList.remove('hidden');
      embedModal.classList.add('flex');
    });
  }

  if (closeEmbedModalBtn && embedModal) {
    closeEmbedModalBtn.addEventListener('click', () => {
      embedModal.classList.add('hidden');
      embedModal.classList.remove('flex');
    });
  }

  if (embedModal) {
    embedModal.addEventListener('click', (e) => {
      if (e.target === embedModal) {
        embedModal.classList.add('hidden');
        embedModal.classList.remove('flex');
      }
    });
  }

  if (copyEmbedModalBtn) {
    copyEmbedModalBtn.addEventListener('click', () => {
      const codeEl = document.getElementById('embed-modal-code');
      if (codeEl) {
        const text = codeEl.textContent || '';
        navigator.clipboard.writeText(text).then(() => {
          copyEmbedModalBtn.textContent = 'Copied!';
          setTimeout(() => copyEmbedModalBtn.textContent = 'Copy to Clipboard', 2000);
        });
      }
    });
  }

  // Copy embed inline
  document.getElementById('copy-embed')?.addEventListener('click', () => {
    const input = document.getElementById('embed-code') as HTMLInputElement | null;
    if (input) {
      input.select();
      document.execCommand('copy');
    }
  });

  // Save
  const saveBtn = document.getElementById('save-btn') as HTMLButtonElement | null;
  if (saveBtn) {
    saveBtn.addEventListener('click', async () => {
      const nameEl = document.getElementById('form-name') as HTMLInputElement | null;
      const submitMessageEl = document.getElementById('submit-message') as HTMLInputElement | null;
      const redirectUrlEl = document.getElementById('redirect-url') as HTMLInputElement | null;
      const activeEl = document.getElementById('form-active') as HTMLInputElement | null;

      const name = nameEl ? nameEl.value : '';
      const submitMessage = submitMessageEl ? submitMessageEl.value : '';
      const redirectUrl = redirectUrlEl ? redirectUrlEl.value : '';
      const active = activeEl ? activeEl.checked : false;

      saveBtn.disabled = true;
      saveBtn.textContent = 'Saving...';

      try {
        const res = await fetch(`/api/admin/forms/${initialForm.id}`, {
          method: 'PATCH',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({
            name,
            fields: fields.map(f => ({
              name: f.name,
              type: f.type,
              label: f.label,
              required: f.required,
              placeholder: f.placeholder,
              options: f.options,
            })),
            submitMessage,
            redirectUrl,
            active,
          }),
        });
        const data = await res.json();

        if (res.ok) {
          window.location.reload();
        } else {
          const errorBanner = document.getElementById('error-banner');
          if (errorBanner) {
            const errP = errorBanner.querySelector('p');
            if (errP) errP.textContent = data.error || 'Failed to save form';
            errorBanner.classList.remove('hidden');
          }
          saveBtn.disabled = false;
          saveBtn.textContent = 'Save Changes';
        }
      } catch (err) {
        const errorBanner = document.getElementById('error-banner');
        if (errorBanner) {
          const errP = errorBanner.querySelector('p');
          if (errP) errP.textContent = 'Network error. Please try again.';
          errorBanner.classList.remove('hidden');
        }
        saveBtn.disabled = false;
        saveBtn.textContent = 'Save Changes';
      }
    });
  }

  // Delete
  const deleteFormBtn = document.getElementById('delete-form-btn') as HTMLElement | null;
  if (deleteFormBtn) {
    deleteFormBtn.addEventListener('click', () => {
      const dialog = document.getElementById('delete-dialog') as HTMLElement | null;
      if (dialog) {
        dialog.classList.remove('hidden');
        dialog.classList.add('flex');
      }
    });
  }

  const deleteCancelBtn = document.getElementById('delete-cancel') as HTMLElement | null;
  if (deleteCancelBtn) {
    deleteCancelBtn.addEventListener('click', () => {
      const dialog = document.getElementById('delete-dialog') as HTMLElement | null;
      if (dialog) {
        dialog.classList.add('hidden');
        dialog.classList.remove('flex');
      }
    });
  }

  const deleteConfirmBtn = document.getElementById('delete-confirm') as HTMLButtonElement | null;
  if (deleteConfirmBtn) {
    deleteConfirmBtn.addEventListener('click', async () => {
      deleteConfirmBtn.disabled = true;
      deleteConfirmBtn.textContent = 'Deleting...';

      try {
        const res = await fetch(`/api/admin/forms/${initialForm.id}`, { method: 'DELETE' });
        if (res.ok) {
          window.location.href = '/admin/forms';
        } else {
          const data = await res.json();
          alert(data.error || 'Failed to delete form');
          deleteConfirmBtn.disabled = false;
          deleteConfirmBtn.textContent = 'Delete';
        }
      } catch (err) {
        alert('Network error');
        deleteConfirmBtn.disabled = false;
        deleteConfirmBtn.textContent = 'Delete';
      }
    });
  }
</script>
