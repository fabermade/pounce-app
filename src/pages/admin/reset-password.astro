---
// /admin/reset-password — Request password reset
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Reset Password — Pounce</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@400;500;600;700&family=Inter:wght@400;500;600&display=swap" rel="stylesheet" />
  <style>
    :root {
      --pounce-orange: #F5A623;
      --charcoal: #1E1E1E;
      --charcoal-light: #333;
      --cream: #FAF7F2;
      --deep-teal: #2A6B6B;
      --gray-100: #f3f4f6;
      --gray-200: #e5e7eb;
      --gray-400: #9ca3af;
      --gray-500: #6b7280;
      --gray-700: #374151;
      --red-50: #fef2f2;
      --red-200: #fecaca;
      --red-600: #dc2626;
      --green-50: #f0fdf4;
      --green-200: #bbf7d0;
      --green-700: #15803d;
      --font-heading: 'Space Grotesk', sans-serif;
      --font-body: 'Inter', sans-serif;
    }
    * { margin: 0; padding: 0; box-sizing: border-box; }
    body {
      font-family: var(--font-body);
      background: var(--cream);
      color: var(--charcoal);
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 2rem;
    }
    .card {
      background: white;
      border-radius: 1rem;
      border: 1px solid var(--gray-200);
      padding: 2.5rem;
      width: 100%;
      max-width: 400px;
    }
    .logo { text-align: center; margin-bottom: 1.5rem; }
    .logo a {
      font-family: var(--font-heading);
      font-size: 1.5rem;
      font-weight: 700;
      text-decoration: none;
    }
    .logo .p { color: var(--pounce-orange); }
    .logo .ounce { color: var(--charcoal); }
    .logo p { color: var(--gray-500); font-size: 0.875rem; margin-top: 0.5rem; }
    .form-group { margin-bottom: 1.25rem; }
    label {
      display: block;
      font-size: 0.875rem;
      font-weight: 500;
      color: var(--gray-700);
      margin-bottom: 0.375rem;
    }
    input[type="email"], input[type="password"] {
      width: 100%;
      padding: 0.75rem 1rem;
      border: 1px solid var(--gray-200);
      border-radius: 0.5rem;
      font-size: 0.875rem;
      font-family: var(--font-body);
      transition: border-color 0.15s, box-shadow 0.15s;
    }
    input:focus {
      outline: none;
      border-color: var(--pounce-orange);
      box-shadow: 0 0 0 3px rgba(245, 166, 35, 0.12);
    }
    button[type="submit"] {
      width: 100%;
      padding: 0.875rem;
      background: var(--charcoal);
      color: white;
      border: none;
      border-radius: 0.5rem;
      font-family: var(--font-heading);
      font-size: 0.9375rem;
      font-weight: 600;
      cursor: pointer;
      transition: background 0.15s;
    }
    button[type="submit"]:hover { background: var(--charcoal-light); }
    button[type="submit"]:disabled {
      opacity: 0.6;
      cursor: not-allowed;
    }
    .error-banner {
      display: none;
      padding: 0.75rem;
      background: var(--red-50);
      border: 1px solid var(--red-200);
      border-radius: 0.5rem;
      margin-bottom: 1rem;
    }
    .error-banner.visible { display: block; }
    .error-banner p { font-size: 0.8125rem; color: var(--red-600); }
    .success-banner {
      display: none;
      padding: 0.75rem;
      background: var(--green-50);
      border: 1px solid var(--green-200);
      border-radius: 0.5rem;
      margin-bottom: 1rem;
    }
    .success-banner.visible { display: block; }
    .success-banner p { font-size: 0.8125rem; color: var(--green-700); }
    .back-link {
      text-align: center;
      margin-top: 1.25rem;
      font-size: 0.8125rem;
    }
    .back-link a { color: var(--gray-500); text-decoration: none; }
    .back-link a:hover { color: var(--charcoal); text-decoration: underline; }
  </style>
</head>
<body>
  <div class="card">
    <div class="logo">
      <a href="/">
        <span class="p">P</span><span class="ounce">ounce</span>
      </a>
      <p>Reset your password</p>
    </div>

    <div id="request-form">
      <div id="error-banner" class="error-banner">
        <p id="error-message"></p>
      </div>
      <div id="success-banner" class="success-banner">
        <p id="success-message"></p>
      </div>

      <form id="reset-form" class="space-y-5">
        <div class="form-group">
          <label>Email</label>
          <input type="email" name="email" required placeholder="you@company.com" />
        </div>
        <button type="submit" id="submit-btn">Send Reset Link</button>
      </form>
    </div>

    <div id="set-password-form" style="display: none;">
      <div id="pw-error-banner" class="error-banner">
        <p id="pw-error-message"></p>
      </div>

      <form id="new-password-form" class="space-y-5">
        <div class="form-group">
          <label>New Password</label>
          <input type="password" name="newPassword" required minlength="8" placeholder="At least 8 characters" />
        </div>
        <div class="form-group">
          <label>Confirm Password</label>
          <input type="password" name="confirmPassword" required placeholder="Repeat your password" />
        </div>
        <input type="hidden" name="token" id="token-input" />
        <button type="submit" id="pw-submit-btn">Set New Password</button>
      </form>
    </div>

    <div class="back-link">
      <a href="/admin/login">Back to sign in</a>
    </div>
  </div>

  <script>
    (function() {
    // Check for token in URL (from invite or reset link)
    const params = new URLSearchParams(window.location.search);
    const token = params.get('token');

    const requestForm = document.getElementById('request-form')!;
    const setPasswordForm = document.getElementById('set-password-form')!;
    const errorBanner = document.getElementById('error-banner')!;
    const errorMessage = document.getElementById('error-message')!;
    const successBanner = document.getElementById('success-banner')!;
    const successMessage = document.getElementById('success-message')!;
    if (requestForm && setPasswordForm && errorBanner && errorMessage && successBanner && successMessage) {

    function showError(msg: string) {
      errorMessage.textContent = msg;
      errorBanner.classList.add('visible');
      successBanner.classList.remove('visible');
    }
    function showSuccess(msg: string) {
      successMessage.textContent = msg;
      successBanner.classList.add('visible');
      errorBanner.classList.remove('visible');
    }

    if (token) {
      requestForm.style.display = 'none';
      setPasswordForm.style.display = 'block';
      const tokenInput = document.getElementById('token-input') as HTMLInputElement | null;
      if (tokenInput) tokenInput.value = token;
    }

    // Request reset
    const resetForm = document.getElementById('reset-form') as HTMLFormElement | null;
    if (resetForm) {
      resetForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const btn = document.getElementById('submit-btn') as HTMLButtonElement | null;
        if (!btn) return;
        btn.disabled = true;
        btn.textContent = 'Sending...';

        const formData = new FormData(e.target as HTMLFormElement);
        const email = formData.get('email');

        try {
          const res = await fetch('/api/admin/reset-password', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ email }),
          });
          const data = await res.json();

          if (res.ok) {
            showSuccess('Check your email for the reset link. (MVP: token is ' + data.token + ')');
            setTimeout(() => {
              requestForm.style.display = 'none';
              setPasswordForm.style.display = 'block';
              const tokenInput2 = document.getElementById('token-input') as HTMLInputElement | null;
              if (tokenInput2) tokenInput2.value = data.token;
            }, 2000);
          } else {
            showError(data.error || 'Failed to send reset link');
          }
        } catch (err) {
          showError('Network error. Please try again.');
        } finally {
          btn.disabled = false;
          btn.textContent = 'Send Reset Link';
        }
      });
    }

    // Set new password
    const newPasswordForm = document.getElementById('new-password-form') as HTMLFormElement | null;
    if (newPasswordForm) {
      newPasswordForm.addEventListener('submit', async (e) => {
        e.preventDefault();
        const formData = new FormData(e.target as HTMLFormElement);
        const newPassword = formData.get('newPassword');
        const confirmPassword = formData.get('confirmPassword');
        const tokenVal = formData.get('token');

        const pwErrorBanner = document.getElementById('pw-error-banner') as HTMLElement | null;
        const pwErrorMessage = document.getElementById('pw-error-message') as HTMLElement | null;
        if (!pwErrorBanner || !pwErrorMessage) return;

        if (newPassword !== confirmPassword) {
          pwErrorMessage.textContent = 'Passwords do not match';
          pwErrorBanner.classList.add('visible');
          return;
        }

        const btn = document.getElementById('pw-submit-btn') as HTMLButtonElement | null;
        if (!btn) return;
        btn.disabled = true;
        btn.textContent = 'Setting password...';

        try {
          const res = await fetch('/api/admin/verify-reset', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify({ token: tokenVal, newPassword }),
          });
          const data = await res.json();

          if (res.ok) {
            window.location.href = '/admin';
          } else {
            pwErrorMessage.textContent = data.error || 'Failed to reset password';
            pwErrorBanner.classList.add('visible');
          }
        } catch (err) {
          pwErrorMessage.textContent = 'Network error. Please try again.';
          pwErrorBanner.classList.add('visible');
        } finally {
          btn.disabled = false;
          btn.textContent = 'Set New Password';
        }
      });
    }
    }  // end if (requestForm && ...)
    })();
  </script>
</body>
</html>
