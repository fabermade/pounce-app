---
// Tone & Voice section with add/remove dos/don'ts
// Props: style, instructions, dos, donts

interface Props {
  style?: string;
  instructions?: string;
  dos?: string[];
  donts?: string[];
}

const { style = 'professional', instructions = '', dos = [], donts = [] } = Astro.props;
---

<div id="section-tone" class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
  <h2 class="text-lg font-semibold font-heading text-charcoal mb-4">Tone & Voice</h2>
  <div class="space-y-4">
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Style Preset</label>
      <select
        name="tone.style"
        class="w-full px-4 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
      >
        <option value="professional" selected={style === 'professional'}>Professional</option>
        <option value="friendly" selected={style === 'friendly'}>Friendly</option>
        <option value="casual" selected={style === 'casual'}>Casual</option>
        <option value="formal" selected={style === 'formal'}>Formal</option>
        <option value="witty" selected={style === 'witty'}>Witty</option>
      </select>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Custom Instructions</label>
      <textarea
        name="tone.instructions"
        rows={3}
        placeholder="e.g. Always mention our free consultation"
        class="w-full px-4 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
      >{instructions}</textarea>
    </div>
    <div class="grid grid-cols-2 gap-4">
      <!-- Dos -->
      <div>
        <div class="flex items-center justify-between mb-2">
          <label class="text-sm font-medium text-gray-700">Dos</label>
          <button type="button" data-add-do class="text-xs text-pounce-orange hover:text-pounce-orange-dark font-medium">+ Add</button>
        </div>
        <div id="dos-list" class="space-y-2">
          <input type="hidden" name="tone.dos" value="__empty_array__" data-empty-marker />
          {dos.length === 0 && (
            <p class="text-sm text-gray-400" data-empty-text>No dos configured.</p>
          )}
          {dos.map((item, i) => (
            <div class="do-item flex items-center gap-2" data-index={i}>
              <svg class="w-4 h-4 text-green-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
              </svg>
              <input
                type="text"
                name={`tone.dos[${i}]`}
                value={item}
                class="text-sm text-gray-600 bg-transparent border-none focus:outline-none flex-1"
              />
              <button type="button" data-remove-do class="text-gray-400 hover:text-red-500 transition-colors">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>
          ))}
        </div>
      </div>
      <!-- Don'ts -->
      <div>
        <div class="flex items-center justify-between mb-2">
          <label class="text-sm font-medium text-gray-700">Don'ts</label>
          <button type="button" data-add-dont class="text-xs text-pounce-orange hover:text-pounce-orange-dark font-medium">+ Add</button>
        </div>
        <div id="donts-list" class="space-y-2">
          <input type="hidden" name="tone.donts" value="__empty_array__" data-empty-marker />
          {donts.length === 0 && (
            <p class="text-sm text-gray-400" data-empty-text>No don'ts configured.</p>
          )}
          {donts.map((item, i) => (
            <div class="dont-item flex items-center gap-2" data-index={i}>
              <svg class="w-4 h-4 text-red-500 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
              </svg>
              <input
                type="text"
                name={`tone.donts[${i}]`}
                value={item}
                class="text-sm text-gray-600 bg-transparent border-none focus:outline-none flex-1"
              />
              <button type="button" data-remove-dont class="text-gray-400 hover:text-red-500 transition-colors">
                <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                </svg>
              </button>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  const dosList = document.getElementById('dos-list');
  const dontsList = document.getElementById('donts-list');

  function addItem(list: HTMLElement, type: string, iconColor: string) {
    const count = list.querySelectorAll(`.${type}-item`).length;
    const div = document.createElement('div');
    div.className = `${type}-item flex items-center gap-2`;
    div.dataset.index = String(count);
    div.innerHTML = `
      <svg class="w-4 h-4 ${iconColor} flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="${type === 'do' ? 'M5 13l4 4L19 7' : 'M6 18L18 6M6 6l12 12'}" />
      </svg>
      <input type="text" name="tone.${type}s[${count}]" placeholder="${type === 'do' ? 'Always...' : 'Never...'}" class="text-sm text-gray-600 bg-transparent border-none focus:outline-none flex-1" />
      <button type="button" data-remove-${type} class="text-gray-400 hover:text-red-500 transition-colors">
        <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
        </svg>
      </button>
    `;
    list.appendChild(div);
    const empty = list.querySelector('[data-empty-text]');
    if (empty) empty.remove();
  }

  document.querySelector('[data-add-do]')?.addEventListener('click', () => {
    if (dosList) addItem(dosList, 'do', 'text-green-500');
  });

  document.querySelector('[data-add-dont]')?.addEventListener('click', () => {
    if (dontsList) addItem(dontsList, 'dont', 'text-red-500');
  });

  dosList?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-remove-do]');
    if (btn) {
      btn.closest('.do-item')?.remove();
      if (dosList.querySelectorAll('.do-item').length === 0) {
        const emptyText = dosList.querySelector('[data-empty-text]');
        if (!emptyText) {
          const p = document.createElement('p');
          p.className = 'text-sm text-gray-400';
          p.dataset.emptyText = '';
          p.textContent = 'No dos configured.';
          dosList.appendChild(p);
        }
      }
    }
  });

  dontsList?.addEventListener('click', (e) => {
    const btn = (e.target as HTMLElement).closest('[data-remove-dont]');
    if (btn) {
      btn.closest('.dont-item')?.remove();
      if (dontsList.querySelectorAll('.dont-item').length === 0) {
        const emptyText = dontsList.querySelector('[data-empty-text]');
        if (!emptyText) {
          const p = document.createElement('p');
          p.className = 'text-sm text-gray-400';
          p.dataset.emptyText = '';
          p.textContent = "No don'ts configured.";
          dontsList.appendChild(p);
        }
      }
    }
  });
</script>
