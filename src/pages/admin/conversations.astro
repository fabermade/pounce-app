---
import AdminPage from '../../layouts/AdminPage.astro';
import AdminLayout from '../../components/admin/AdminLayout';
import { db, conversations, leads, messages } from '../../lib/db/index.js';
import { eq, desc } from 'drizzle-orm';

const leadId = Astro.url.searchParams.get('leadId');

// Read conversations directly from DB
const allConversations = await db
  .select()
  .from(conversations)
  .orderBy(desc(conversations.createdAt))
  .limit(50);

// Enrich with lead info and messages
const enrichedConversations = await Promise.all(
  allConversations.map(async (conv) => {
    const [lead] = await db.select().from(leads).where(eq(leads.id, conv.leadId)).limit(1);
    const convMessages = await db.select().from(messages).where(eq(messages.conversationId, conv.id)).orderBy(messages.createdAt);
    return {
      ...conv,
      lead: lead || { name: 'Unknown', email: 'unknown@example.com', company: null },
      messages: convMessages,
    };
  })
);

// Filter by leadId if specified
const filteredConversations = leadId
  ? enrichedConversations.filter(c => c.leadId === leadId)
  : enrichedConversations;

const selectedConv = filteredConversations.length > 0 ? filteredConversations[0] : null;

const statusColors: Record<string, string> = {
  new: 'bg-blue-100 text-blue-800',
  contacted: 'bg-yellow-100 text-yellow-800',
  customer_waiting: 'bg-orange-100 text-orange-800',
  scheduled: 'bg-green-100 text-green-800',
  closed_won: 'bg-green-100 text-green-800',
  closed_lost: 'bg-gray-100 text-gray-600',
  escalated: 'bg-red-100 text-red-800',
  opted_out: 'bg-gray-100 text-gray-400',
};

const statusLabels: Record<string, string> = {
  new: 'New',
  contacted: 'Contacted',
  customer_waiting: 'Customer Waiting',
  scheduled: 'Scheduled',
  closed_won: 'Closed Won',
  closed_lost: 'Closed Lost',
  escalated: 'Escalated',
  opted_out: 'Opted Out',
};

// Helper to group messages by date
function groupMessagesByDate(msgs: typeof selectedConv.messages) {
  const groups: { date: string; messages: typeof msgs }[] = [];
  msgs.forEach(msg => {
    const date = new Date(msg.createdAt).toLocaleDateString([], { month: 'short', day: 'numeric', year: 'numeric' });
    const lastGroup = groups[groups.length - 1];
    if (lastGroup && lastGroup.date === date) {
      lastGroup.messages.push(msg);
    } else {
      groups.push({ date, messages: [msg] });
    }
  });
  return groups;
}

const messageGroups = selectedConv ? groupMessagesByDate(selectedConv.messages) : [];

// Check if AI responded to latest customer message
const hasAIResponse = selectedConv?.messages.some((m, i) => {
  if (m.source !== 'ai') return false;
  // Find previous customer message
  for (let j = i - 1; j >= 0; j--) {
    if (selectedConv.messages[j].source === 'customer') return true;
    if (selectedConv.messages[j].source !== 'ai') break;
  }
  return false;
});
---

<AdminPage title="Conversations" currentPath="/admin/conversations">
  <AdminLayout currentPath="/admin/conversations">
    <div class="p-8">
      <!-- Header -->
      <div class="mb-8">
        <h1 class="text-3xl font-bold font-heading text-charcoal mb-2">Conversations</h1>
        <p class="text-gray-500">View and manage lead conversations</p>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6">
        <!-- Conversation List -->
        <div class="lg:col-span-1">
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="p-4 border-b border-gray-100">
              <h2 class="text-sm font-semibold text-charcoal">Active Conversations</h2>
            </div>
            {filteredConversations.length === 0 ? (
              <div class="p-8 text-center text-gray-400">
                <p class="text-sm">No conversations yet.</p>
              </div>
            ) : (
              <div class="divide-y divide-gray-100 max-h-[600px] overflow-y-auto">
                {filteredConversations.map((conv) => {
                  const leadData = conv.lead as { name: string | null; email: string; company: string | null };
                  const lastMessage = conv.messages.length > 0 ? conv.messages[conv.messages.length - 1] : null;
                  return (
                    <a
                      href={`/admin/conversations?leadId=${conv.id}`}
                      class={`block p-4 hover:bg-gray-50 transition-colors ${(conv.lead as any).status === 'new' ? 'bg-blue-50/50' : ''}`}
                    >
                      <div class="flex items-start justify-between mb-2">
                        <div class="flex items-center gap-2">
                          <div class="w-8 h-8 rounded-full bg-gray-100 flex items-center justify-center text-xs font-medium text-gray-600">
                            {(leadData.name || leadData.email).charAt(0).toUpperCase()}
                          </div>
                          <div>
                            <p class="font-medium text-charcoal text-sm">{leadData.name || 'Unknown'}</p>
                            <p class="text-xs text-gray-500">{leadData.company || leadData.email}</p>
                          </div>
                        </div>
                        {conv.awaitingReply && (
                          <span class="w-2 h-2 bg-pounce-orange rounded-full"></span>
                        )}
                      </div>
                      {lastMessage && (
                        <>
                          <p class="text-sm text-gray-600 line-clamp-2">{lastMessage.content}</p>
                          <div class="mt-2 flex items-center gap-2">
                            <span class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-medium ${statusColors[(conv.lead as any).status] || 'bg-gray-100 text-gray-800'}`}>
                              {statusLabels[(conv.lead as any).status] || (conv.lead as any).status || 'Unknown'}
                            </span>
                            <span class="text-xs text-gray-400">
                              {new Date(lastMessage.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}
                            </span>
                          </div>
                        </>
                      )}
                    </a>
                  );
                })}
              </div>
            )}
          </div>
        </div>

        <!-- Conversation Detail -->
        <div class="lg:col-span-2">
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 flex flex-col h-[600px]">
            {selectedConv ? (
              <>
                <!-- Conversation Header -->
                <div class="p-4 border-b border-gray-100 flex items-center justify-between">
                  <div class="flex items-center gap-3">
                    <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center text-sm font-medium text-gray-600">
                      {((selectedConv.lead as { name: string | null; email: string }).name || (selectedConv.lead as { email: string }).email).charAt(0).toUpperCase()}
                    </div>
                    <div>
                      <p class="font-medium text-charcoal">{(selectedConv.lead as { name: string | null }).name || 'Unknown'}</p>
                      <p class="text-sm text-gray-500">{(selectedConv.lead as { email: string }).email}</p>
                    </div>
                  </div>
                  <div class="flex items-center gap-2">
                    {selectedConv.lead && (selectedConv.lead as any).status === 'scheduled' && (
                      <span class="inline-flex items-center gap-1 px-2.5 py-1 rounded-full bg-green-50 text-green-700 text-xs font-medium">
                        <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z" />
                        </svg>
                        Scheduled
                      </span>
                    )}
                    <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${statusColors[(selectedConv.lead as any).status] || 'bg-gray-100 text-gray-800'}`}>
                      {statusLabels[(selectedConv.lead as any).status] || (selectedConv.lead as any).status}
                    </span>
                  </div>
                </div>

                <!-- Messages with Date Grouping -->
                <div class="flex-1 overflow-y-auto p-4 space-y-4">
                  {messageGroups.map((group) => (
                    <>
                      <!-- Date Divider -->
                      <div class="flex items-center gap-3 my-4">
                        <div class="flex-1 h-px bg-gray-200"></div>
                        <span class="text-xs text-gray-400 font-medium">{group.date}</span>
                        <div class="flex-1 h-px bg-gray-200"></div>
                      </div>

                      {group.messages.map((message) => (
                        <div class={`flex ${message.source === 'customer' ? 'justify-start' : 'justify-end'}`}>
                          <div class={`max-w-[75%] rounded-2xl px-4 py-3 ${
                            message.source === 'customer'
                              ? 'bg-gray-100 text-charcoal rounded-bl-none'
                              : message.source === 'ai'
                              ? 'bg-[#E8F4FD] text-charcoal rounded-br-none border border-blue-200'
                              : 'bg-[#FEF3E2] text-charcoal rounded-br-none border border-orange-200'
                          }`}>
                            <!-- AI Reply Indicator -->
                            {message.source === 'ai' && (
                              <div class="flex items-center gap-1.5 mb-2 pb-2 border-b border-blue-200/50">
                                <svg class="w-3.5 h-3.5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                                </svg>
                                <span class="text-xs font-medium text-blue-600">AI responded</span>
                              </div>
                            )}

                            <p class="text-sm leading-relaxed">{message.content}</p>
                            <div class="flex items-center gap-2 mt-2">
                              <span class="text-xs text-gray-400">
                                {new Date(message.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}
                              </span>
                              {message.source === 'ai' && (
                                <span class="inline-flex items-center gap-1 text-xs font-medium text-blue-600">
                                  <svg class="w-3 h-3" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9.75 17L9 20l-1 1h8l-1-1-.75-3M3 13h18M5 17h14a2 2 0 002-2V5a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
                                  </svg>
                                  AI
                                </span>
                              )}
                              {message.source === 'human' && (
                                <span class="text-xs font-medium text-orange-600">You</span>
                              )}
                              {message.source === 'customer' && (
                                <span class="text-xs font-medium text-gray-500">Lead</span>
                              )}
                            </div>
                          </div>
                        </div>
                      ))}
                    </>
                  ))}
                </div>

                <!-- Reply Input -->
                <div class="p-4 border-t border-gray-100">
                  <div class="flex gap-3">
                    <input
                      type="text"
                      placeholder="Type your reply..."
                      class="flex-1 px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
                    />
                    <button class="px-6 py-3 bg-pounce-orange text-white rounded-lg font-medium hover:bg-pounce-orange-dark transition-colors text-sm">
                      Send
                    </button>
                  </div>
                  <p class="text-xs text-gray-400 mt-2">Press Enter to send, Shift+Enter for new line</p>
                </div>
              </>
            ) : (
              <div class="flex-1 flex items-center justify-center text-gray-400">
                <div class="text-center">
                  <svg class="w-12 h-12 mx-auto mb-3 text-gray-300" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z" />
                  </svg>
                  <p class="text-sm">Select a conversation to view messages</p>
                </div>
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  </AdminLayout>
</AdminPage>
