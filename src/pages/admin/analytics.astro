---
import AdminPage from '../../layouts/AdminPage.astro';
import AdminLayout from '../../components/admin/AdminLayout';
import { db, leads, events } from '../../lib/db/index.js';
import { desc, sql } from 'drizzle-orm';

// Read analytics directly from DB
const allLeads = await db.select().from(leads);
const totalLeads = allLeads.length;

// Status breakdown
const statusGroups = allLeads.reduce((acc, lead) => {
  acc[lead.status] = (acc[lead.status] || 0) + 1;
  return acc;
}, {} as Record<string, number>);

const statusBreakdown = Object.entries(statusGroups).map(([status, count]) => ({ status, count }));

// Recent events (last 50)
const recentEvents = await db.select().from(events).orderBy(desc(events.createdAt)).limit(50);

const statusColors: Record<string, string> = {
  new: 'bg-blue-100 text-blue-800',
  contacted: 'bg-yellow-100 text-yellow-800',
  customer_waiting: 'bg-orange-100 text-orange-800',
  scheduled: 'bg-green-100 text-green-800',
  closed_won: 'bg-green-100 text-green-800',
  closed_lost: 'bg-gray-100 text-gray-600',
  escalated: 'bg-red-100 text-red-800',
  opted_out: 'bg-gray-100 text-gray-400',
};

const statusLabels: Record<string, string> = {
  new: 'New',
  contacted: 'Contacted',
  customer_waiting: 'Customer Waiting',
  scheduled: 'Scheduled',
  closed_won: 'Closed Won',
  closed_lost: 'Closed Lost',
  escalated: 'Escalated',
  opted_out: 'Opted Out',
};
---

<AdminPage title="Analytics" currentPath="/admin/analytics">
  <AdminLayout currentPath="/admin/analytics">
    <div class="p-8">
      <!-- Header -->
      <div class="mb-8">
        <h1 class="text-3xl font-bold font-heading text-charcoal mb-2">Analytics</h1>
        <p class="text-gray-500">Track your lead pipeline performance</p>
      </div>

      <!-- Stats Cards -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <p class="text-sm text-gray-500 mb-1">Total Leads</p>
          <p class="text-3xl font-bold font-heading text-charcoal">{totalLeads}</p>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <p class="text-sm text-gray-500 mb-1">Status Breakdown</p>
          <div class="flex flex-wrap gap-2 mt-2">
            {statusBreakdown.map(({ status, count }) => (
              <span class={`inline-flex items-center px-2 py-0.5 rounded text-xs font-medium ${statusColors[status] || 'bg-gray-100 text-gray-800'}`}>
                {statusLabels[status] || status}: {count}
              </span>
            ))}
          </div>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <p class="text-sm text-gray-500 mb-1">Responded</p>
          <p class="text-3xl font-bold font-heading text-charcoal">
            {allLeads.filter(l => l.status !== 'new').length}
          </p>
        </div>
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <p class="text-sm text-gray-500 mb-1">Booked</p>
          <p class="text-3xl font-bold font-heading text-charcoal">
            {allLeads.filter(l => l.status === 'scheduled').length}
          </p>
        </div>
      </div>

      <!-- Status Breakdown -->
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-8">
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <h2 class="text-lg font-semibold font-heading text-charcoal mb-4">Lead Status</h2>
          <div class="space-y-3">
            {statusBreakdown.map(({ status, count }) => {
              const pct = totalLeads > 0 ? Math.round((count / totalLeads) * 100) : 0;
              return (
                <div>
                  <div class="flex items-center justify-between mb-1">
                    <span class="text-sm text-gray-600">{statusLabels[status] || status}</span>
                    <span class="text-sm font-medium text-charcoal">{count} ({pct}%)</span>
                  </div>
                  <div class="w-full bg-gray-100 rounded-full h-2">
                    <div class={`h-2 rounded-full ${statusColors[status]?.split(' ')[0] || 'bg-gray-300'}`} style={`width: ${pct}%`}></div>
                  </div>
                </div>
              );
            })}
          </div>
        </div>

        <!-- Recent Activity -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <h2 class="text-lg font-semibold font-heading text-charcoal mb-4">Recent Activity</h2>
          <div class="space-y-3 max-h-[400px] overflow-y-auto">
            {recentEvents.length === 0 && (
              <p class="text-sm text-gray-400">No activity yet.</p>
            )}
            {recentEvents.map((event) => (
              <div class="flex items-start gap-3">
                <div class="w-2 h-2 bg-pounce-orange rounded-full mt-2"></div>
                <div>
                  <p class="text-sm text-charcoal">{event.type.replace(/_/g, ' ')}</p>
                  <p class="text-xs text-gray-400">{new Date(event.createdAt).toLocaleString()}</p>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Leads by Source -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h2 class="text-lg font-semibold font-heading text-charcoal mb-4">Leads by Source</h2>
        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {Object.entries(
            allLeads.reduce((acc, lead) => {
              acc[lead.source] = (acc[lead.source] || 0) + 1;
              return acc;
            }, {} as Record<string, number>)
          ).map(([source, count]) => (
            <div class="text-center p-4 bg-gray-50 rounded-lg">
              <p class="text-2xl font-bold text-charcoal">{count}</p>
              <p class="text-sm text-gray-500 capitalize">{source}</p>
            </div>
          ))}
        </div>
      </div>
    </div>
  </AdminLayout>
</AdminPage>