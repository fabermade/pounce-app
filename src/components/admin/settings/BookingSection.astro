---
// Booking section component
// Props: booking config (url, ctaText, timing, provider)

interface Props {
  url?: string;
  ctaText?: string;
  timing?: string;
  provider?: string;
}

const { url = '', ctaText = 'Book a call', timing = 'after_first_exchange', provider = '' } = Astro.props;

const timingOptions = [
  { value: 'immediately', label: 'Immediately' },
  { value: 'after_first_exchange', label: 'After first exchange' },
  { value: 'after_second_exchange', label: 'After second exchange' },
  { value: 'manual', label: 'Manual (don\'t suggest)' },
];

const providerOptions = [
  { value: '', label: 'None' },
  { value: 'calcom', label: 'Cal.com' },
  { value: 'calendly', label: 'Calendly' },
];
---

<div id="section-booking" class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
  <div class="flex items-center justify-between mb-4">
    <h2 class="text-lg font-semibold font-heading text-charcoal">Booking</h2>
    <a href="/book" target="_blank" class="text-sm text-pounce-orange hover:underline">Preview Page</a>
  </div>
  <div class="space-y-4">
    <!-- Provider Selector -->
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Booking Provider</label>
      <select
        name="providers.booking"
        class="w-full px-4 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
      >
        {providerOptions.map((opt) => (
          <option value={opt.value} selected={provider === opt.value}>{opt.label}</option>
        ))}
      </select>
    </div>

    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Calendar URL</label>
      <input
        type="url"
        name="booking.url"
        value={url}
        placeholder="https://cal.com/yourname"
        class="w-full px-4 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
      />
      <p class="text-xs text-gray-400 mt-1">Your Cal.com, Calendly, or other scheduling link.</p>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">CTA Text</label>
      <input
        type="text"
        name="booking.ctaText"
        value={ctaText}
        placeholder="Book a call"
        class="w-full px-4 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
      />
      <p class="text-xs text-gray-400 mt-1">This is what the AI says when suggesting a booking.</p>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">When to suggest booking</label>
      <select
        name="booking.timing"
        class="w-full px-4 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
      >
        {timingOptions.map((opt) => (
          <option value={opt.value} selected={timing === opt.value}>{opt.label}</option>
        ))}
      </select>
    </div>


  </div>
</div>
