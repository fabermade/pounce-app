---
import AdminPage from '../../layouts/AdminPage.astro';

// Check setup status
let setupStatus = { completed: false };
let error: string | null = null;

try {
  // BOLT: Need GET /api/admin/setup/status
  const response = await fetch(new URL('/api/admin/setup/status', Astro.url.origin));
  if (response.ok) {
    setupStatus = await response.json();
  }
} catch (e) {
  // If endpoint doesn't exist yet, assume setup is needed
  setupStatus = { completed: false };
}

// If setup is complete, redirect to dashboard
if (setupStatus.completed) {
  return Astro.redirect('/admin');
}

const steps = [
  { id: 'business', label: 'Business Info', description: 'Tell us about your company' },
  { id: 'llm', label: 'AI Provider', description: 'Choose your LLM provider' },
  { id: 'email', label: 'Email', description: 'Configure email sending' },
  { id: 'escalation', label: 'Escalation', description: 'Set up human handoff' },
  { id: 'booking', label: 'Booking', description: 'Add your calendar link' },
];
---

<AdminPage title="Setup" currentPath="/admin/setup">
  <div class="min-h-screen flex items-center justify-center p-8">
    <div class="w-full max-w-2xl">
      <!-- Logo -->
      <div class="text-center mb-8">
        <a href="/" class="text-3xl font-bold font-heading">
          <span class="text-pounce-orange">P</span>
          <span class="text-charcoal">ounce</span>
        </a>
        <h1 class="text-2xl font-bold font-heading text-charcoal mt-4 mb-2">Welcome to Pounce</h1>
        <p class="text-gray-500">Let's get your AI lead response agent set up.</p>
      </div>

      <!-- Stepper -->
      <div class="mb-8">
        <div class="flex items-center justify-between">
          {steps.map((step, index) => (
            <div class="flex flex-col items-center">
              <div class={`w-8 h-8 rounded-full flex items-center justify-center text-sm font-medium ${
                index === 0
                  ? 'bg-pounce-orange text-white'
                  : 'bg-gray-100 text-gray-500'
              }`}>
                {index + 1}
              </div>
              <span class="text-xs text-gray-500 mt-1 hidden sm:block">{step.label}</span>
            </div>
          ))}
        </div>
      </div>

      <!-- Form -->
      <form
        action="/api/admin/setup"
        method="POST"
        class="bg-white rounded-xl shadow-sm border border-gray-100 p-8 space-y-6"
      >
        <!-- Step 1: Business Info -->
        <div>
          <h2 class="text-lg font-semibold font-heading text-charcoal mb-4">Business Information</h2>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Business Name *</label>
              <input
                type="text"
                name="business.name"
                required
                placeholder="Acme Inc"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Tagline</label>
              <input
                type="text"
                name="business.tagline"
                placeholder="We make the best widgets"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Website</label>
              <input
                type="url"
                name="business.website"
                placeholder="https://example.com"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
              <textarea
                name="business.description"
                rows={3}
                placeholder="What does your business do?"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
              ></textarea>
            </div>
          </div>
        </div>

        <hr class="border-gray-100" />

        <!-- Step 2: LLM Provider -->
        <div>
          <h2 class="text-lg font-semibold font-heading text-charcoal mb-4">AI Provider</h2>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">LLM Provider *</label>
              <select
                name="providers.llm"
                required
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
              >
                <option value="">Select a provider</option>
                <option value="openai">OpenAI</option>
                <option value="anthropic">Anthropic</option>
                <option value="ollama">Ollama (self-hosted)</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">API Key *</label>
              <input
                type="password"
                name="providers.llmApiKey"
                required
                placeholder="sk-..."
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
              />
              <p class="text-xs text-gray-400 mt-1">Your API key is encrypted and never shared.</p>
            </div>
          </div>
        </div>

        <hr class="border-gray-100" />

        <!-- Step 3: Email Provider -->
        <div>
          <h2 class="text-lg font-semibold font-heading text-charcoal mb-4">Email Configuration</h2>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Email Provider *</label>
              <select
                name="providers.email"
                required
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
              >
                <option value="">Select a provider</option>
                <option value="resend">Resend</option>
                <option value="sendgrid">SendGrid</option>
                <option value="mailgun">Mailgun</option>
              </select>
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Email API Key *</label>
              <input
                type="password"
                name="providers.emailApiKey"
                required
                placeholder="Your email provider API key"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
              />
            </div>
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">From Email Address *</label>
              <input
                type="email"
                name="providers.fromEmail"
                required
                placeholder="hello@yourcompany.com"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
              />
            </div>
          </div>
        </div>

        <hr class="border-gray-100" />

        <!-- Step 4: Escalation -->
        <div>
          <h2 class="text-lg font-semibold font-heading text-charcoal mb-4">Escalation Rules</h2>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Escalation Email *</label>
              <input
                type="email"
                name="escalation.notifyEmail"
                required
                placeholder="you@yourcompany.com"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
              />
              <p class="text-xs text-gray-400 mt-1">You'll be notified when a lead needs human attention.</p>
            </div>
          </div>
        </div>

        <hr class="border-gray-100" />

        <!-- Step 5: Booking -->
        <div>
          <h2 class="text-lg font-semibold font-heading text-charcoal mb-4">Booking Link</h2>
          <div class="space-y-4">
            <div>
              <label class="block text-sm font-medium text-gray-700 mb-1">Calendar URL</label>
              <input
                type="url"
                name="booking.url"
                placeholder="https://cal.com/yourname"
                class="w-full px-4 py-3 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
              />
              <p class="text-xs text-gray-400 mt-1">Optional. The AI will offer this link when a lead wants to book a call.</p>
            </div>
          </div>
        </div>

        <!-- Submit -->
        <div class="pt-4">
          <button
            type="submit"
            class="w-full px-6 py-3 bg-pounce-orange text-white rounded-lg font-medium hover:bg-pounce-orange-dark transition-colors"
          >
            Complete Setup
          </button>
          <p class="text-xs text-gray-400 text-center mt-3">You can update these settings anytime from the admin dashboard.</p>
        </div>
      </form>
    </div>
  </div>

  <script>
    // Client-side form handling
    const form = document.querySelector('form');
    form?.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formData = new FormData(form);
      const data = Object.fromEntries(formData.entries());

      try {
        const response = await fetch('/api/admin/setup', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify(data),
        });

        if (response.ok) {
          window.location.href = '/admin';
        } else {
          const err = await response.json().catch(() => ({ error: 'Setup failed' }));
          alert(err.error || 'Setup failed. Please try again.');
        }
      } catch (err) {
        alert('Network error. Please try again.');
      }
    });
  </script>
</AdminPage>