---
const session = Astro.locals.session;
const currentUser = session ? { name: session.name || null, email: session.email } : null;
import AdminPage from '../../layouts/AdminPage.astro';
import AdminLayout from '../../components/admin/AdminLayout';

// Fetch forms from API
let forms: Array<{id: string; name: string; slug: string; active: boolean; createdAt: string}> = [];
let error: string | null = null;

try {
  const res = await fetch(`${Astro.url.origin}/api/admin/forms`, {
    headers: { 'Cookie': Astro.request.headers.get('cookie') || '' }
  });
  if (res.ok) {
    const data = await res.json();
    forms = data.forms || [];
  } else {
    error = 'Failed to load forms';
  }
} catch (e) {
  error = 'Failed to load forms';
}
---

<AdminPage title="Forms" currentPath="/admin/forms">
<AdminLayout currentPath="/admin/forms" currentUser={currentUser}>
  <div class="p-8 max-w-5xl mx-auto">
    <div class="flex items-center justify-between mb-8">
      <div>
        <h1 class="text-2xl font-bold font-heading text-charcoal">Forms</h1>
        <p class="text-sm text-gray-500 mt-1">Create and manage lead capture forms</p>
      </div>
      <a
        href="/admin/forms/new"
        class="px-4 py-2.5 bg-charcoal text-white rounded-lg text-sm font-medium hover:bg-charcoal-light transition-colors inline-flex items-center gap-2"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="5" x2="12" y2="19"></line><line x1="5" y1="12" x2="19" y2="12"></line></svg>
        New Form
      </a>
    </div>

    {error && (
      <div class="mb-4 p-3 bg-red-50 border border-red-200 rounded-lg">
        <p class="text-sm text-red-600">{error}</p>
      </div>
    )}

    <div class="bg-white rounded-xl border border-gray-200 overflow-hidden">
      <table class="w-full">
        <thead>
          <tr class="border-b border-gray-100 bg-gray-50/50">
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Name</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Slug</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
            <th class="px-6 py-3 text-left text-xs font-medium text-gray-500 uppercase tracking-wider">Created</th>
            <th class="px-6 py-3 text-right text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-gray-100">
          {forms.map((form) => (
            <tr class="hover:bg-gray-50/50 transition-colors">
              <td class="px-6 py-4">
                <a href={`/admin/forms/${form.id}`} class="text-sm font-medium text-charcoal hover:text-pounce-orange transition-colors">
                  {form.name}
                </a>
              </td>
              <td class="px-6 py-4 text-sm text-gray-600 font-mono">{form.slug}</td>
              <td class="px-6 py-4">
                <span class={`inline-flex px-2 py-0.5 rounded-full text-xs font-medium ${
                  form.active ? 'bg-green-50 text-green-700' : 'bg-gray-100 text-gray-500'
                }`}>
                  {form.active ? 'Active' : 'Inactive'}
                </span>
              </td>
              <td class="px-6 py-4 text-sm text-gray-500">{new Date(form.createdAt).toLocaleDateString()}</td>
              <td class="px-6 py-4 text-right">
                <div class="flex items-center justify-end gap-2">
                  <a
                    href={`/admin/forms/${form.id}`}
                    class="text-sm text-gray-500 hover:text-charcoal transition-colors"
                  >
                    Edit
                  </a>
                  <button
                    class="delete-btn text-sm text-red-500 hover:text-red-700 transition-colors"
                    data-form-id={form.id}
                    data-form-name={form.name}
                  >
                    Delete
                  </button>
                </div>
              </td>
            </tr>
          ))}
        </tbody>
      </table>
      {forms.length === 0 && !error && (
        <div class="p-8 text-center">
          <p class="text-sm text-gray-500 mb-2">No forms yet.</p>
          <a href="/admin/forms/new" class="text-sm text-pounce-orange hover:underline">Create your first form</a>
        </div>
      )}
    </div>
  </div>

  {/* Delete Dialog */}
  <div id="delete-dialog" class="fixed inset-0 bg-black/50 z-50 hidden items-center justify-center">
    <div class="bg-white rounded-xl shadow-lg border border-gray-200 w-full max-w-sm mx-4 p-6">
      <h2 class="text-lg font-bold font-heading text-charcoal mb-1">Delete Form</h2>
      <p class="text-sm text-gray-500 mb-5">Are you sure you want to delete <span id="delete-form-name" class="font-medium text-charcoal"></span>? This cannot be undone.</p>

      <div class="flex items-center justify-end gap-3">
        <button type="button" id="delete-cancel" class="px-4 py-2 text-sm text-gray-600 hover:text-charcoal transition-colors">Cancel</button>
        <button type="button" id="delete-confirm" class="px-4 py-2 bg-red-600 text-white rounded-lg text-sm font-medium hover:bg-red-700 transition-colors">Delete</button>
      </div>
    </div>
  </div>
</AdminLayout>
</AdminPage>

<script>
  const deleteDialog = document.getElementById('delete-dialog') as HTMLElement | null;
  const deleteCancel = document.getElementById('delete-cancel') as HTMLElement | null;
  const deleteConfirm = document.getElementById('delete-confirm') as HTMLButtonElement | null;
  const deleteFormNameEl = document.getElementById('delete-form-name') as HTMLElement | null;
  if (deleteDialog && deleteCancel && deleteConfirm && deleteFormNameEl) {
    let deleteFormId = '';

    document.querySelectorAll('.delete-btn').forEach(btn => {
      btn.addEventListener('click', () => {
        const el = btn as HTMLElement;
        deleteFormId = el.dataset.formId || '';
        deleteFormNameEl.textContent = el.dataset.formName || '';
        deleteDialog.classList.remove('hidden');
        deleteDialog.classList.add('flex');
      });
    });

    deleteCancel.addEventListener('click', () => {
      deleteDialog.classList.add('hidden');
      deleteDialog.classList.remove('flex');
    });

    deleteConfirm.addEventListener('click', async () => {
      if (!deleteFormId) return;
      deleteConfirm.disabled = true;
      deleteConfirm.textContent = 'Deleting...';

      try {
        const res = await fetch(`/api/admin/forms/${deleteFormId}`, {
          method: 'DELETE',
        });
        if (res.ok) {
          window.location.reload();
        } else {
          const data = await res.json();
          alert(data.error || 'Failed to delete form');
          deleteConfirm.disabled = false;
          deleteConfirm.textContent = 'Delete';
        }
      } catch (err) {
        alert('Network error. Please try again.');
        deleteConfirm.disabled = false;
        deleteConfirm.textContent = 'Delete';
      }
    });
  }
</script>
