---
import AdminPage from '../../layouts/AdminPage.astro';
import AdminLayout from '../../components/admin/AdminLayout';

const session = Astro.locals.session;
const currentUser = session ? { name: session.name || null, email: session.email } : null;

// Fetch data from APIs
let stats = { totalLeads: 0, responseRate: 0, avgResponseTime: '0', bookingRate: 0, leadsThisWeek: 0, leadsLastWeek: 0 };
let recentLeads: Array<{
  id: string;
  name: string | null;
  email: string;
  company: string | null;
  status: string;
  message: string | null;
  createdAt: Date;
}> = [];
let error: string | null = null;

try {
  const [analyticsRes, leadsRes] = await Promise.all([
    fetch(new URL('/api/admin/analytics', Astro.url.origin)),
    fetch(new URL('/api/admin/leads?limit=5', Astro.url.origin)),
  ]);

  if (analyticsRes.ok) {
    const analyticsData = await analyticsRes.json();
    stats = analyticsData.stats;
  }

  if (leadsRes.ok) {
    const leadsData = await leadsRes.json();
    recentLeads = leadsData.leads;
  }
} catch (e) {
  error = 'Network error. Please try again.';
}

const statCards = [
  { label: 'Total Leads', value: stats.totalLeads, change: `+${stats.leadsThisWeek - stats.leadsLastWeek}`, trend: stats.leadsThisWeek >= stats.leadsLastWeek ? 'up' : 'down' as const },
  { label: 'Response Rate', value: `${stats.responseRate}%`, change: '+2%', trend: 'up' as const },
  { label: 'Avg Response Time', value: `${stats.avgResponseTime}s`, change: '-0.5s', trend: 'up' as const },
  { label: 'Booking Rate', value: `${stats.bookingRate}%`, change: '+5%', trend: 'up' as const },
];

const statusColors: Record<string, string> = {
  new: 'bg-blue-100 text-blue-800',
  contacted: 'bg-yellow-100 text-yellow-800',
  customer_waiting: 'bg-orange-100 text-orange-800',
  scheduled: 'bg-green-100 text-green-800',
  closed_won: 'bg-green-100 text-green-800',
  closed_lost: 'bg-gray-100 text-gray-600',
  escalated: 'bg-red-100 text-red-800',
  opted_out: 'bg-gray-100 text-gray-400',
};

const statusLabels: Record<string, string> = {
  new: 'New',
  contacted: 'Contacted',
  customer_waiting: 'Customer Waiting',
  scheduled: 'Scheduled',
  closed_won: 'Closed Won',
  closed_lost: 'Closed Lost',
  escalated: 'Escalated',
  opted_out: 'Opted Out',
};
---

<AdminPage title="Dashboard" currentPath="/admin">
  <AdminLayout currentPath="/admin" currentUser={currentUser}>
    <div class="p-8">
      <!-- Header -->
      <div class="mb-8">
        <h1 class="text-3xl font-bold font-heading text-charcoal mb-2">Dashboard</h1>
        <p class="text-gray-500">Overview of your lead pipeline</p>
      </div>

      <!-- Error State -->
      {error && (
        <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg">
          <p class="text-sm text-red-600">{error}</p>
        </div>
      )}

      <!-- Stats Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        {statCards.map((stat) => (
          <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
            <p class="text-sm text-gray-500 mb-1">{stat.label}</p>
            <div class="flex items-end gap-2">
              <span class="text-3xl font-bold text-charcoal">{stat.value}</span>
              <span class={`text-sm font-medium mb-1 ${stat.trend === 'up' ? 'text-green-600' : 'text-red-600'}`}>
                {stat.change}
              </span>
            </div>
          </div>
        ))}
      </div>

      <!-- Recent Leads -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-100">
        <div class="p-6 border-b border-gray-100 flex items-center justify-between">
          <h2 class="text-lg font-semibold font-heading text-charcoal">Recent Leads</h2>
          <a href="/admin/leads" class="text-sm text-pounce-orange hover:text-pounce-orange-dark font-medium">
            View all →
          </a>
        </div>
        {recentLeads.length === 0 ? (
          <div class="p-12 text-center text-gray-400">
            <p class="text-sm">No leads yet.</p>
            <p class="text-xs mt-1">Leads will appear here when they come in.</p>
          </div>
        ) : (
          <div class="divide-y divide-gray-100">
            {recentLeads.map((lead) => (
              <div class="p-6 hover:bg-gray-50 transition-colors">
                <div class="flex items-start justify-between">
                  <div class="flex-1">
                    <div class="flex items-center gap-3 mb-1">
                      <h3 class="font-semibold text-charcoal">{lead.name || 'Unknown'}</h3>
                      <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${statusColors[lead.status] || 'bg-gray-100 text-gray-800'}`}>
                        {statusLabels[lead.status] || lead.status}
                      </span>
                    </div>
                    <p class="text-sm text-gray-500">{lead.email} {lead.company && `· ${lead.company}`}</p>
                    <p class="text-sm text-gray-600 mt-2">{lead.message || 'No message'}</p>
                  </div>
                  <span class="text-xs text-gray-400">{new Date(lead.createdAt).toLocaleDateString()}</span>
                </div>
              </div>
            ))}
          </div>
        )}
      </div>
    </div>
  </AdminLayout>
</AdminPage>
