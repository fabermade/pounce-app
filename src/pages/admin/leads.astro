---
import AdminPage from '../../layouts/AdminPage.astro';
import AdminLayout from '../../components/admin/AdminLayout';

// Fetch leads from API
let leadsData: {
  leads: Array<{
    id: string;
    name: string | null;
    email: string;
    company: string | null;
    status: string;
    source: string;
    message: string | null;
    createdAt: Date;
  }>;
  pagination: {
    page: number;
    limit: number;
    total: number;
    totalPages: number;
  };
} = { leads: [], pagination: { page: 1, limit: 25, total: 0, totalPages: 0 } };

let error: string | null = null;

try {
  const url = new URL('/api/admin/leads', Astro.url.origin);
  const response = await fetch(url.toString());
  if (response.ok) {
    leadsData = await response.json();
  } else {
    const errData = await response.json().catch(() => ({ error: 'Failed to fetch leads' }));
    error = errData.error || `Error ${response.status}`;
  }
} catch (e) {
  error = 'Network error. Please try again.';
}

const statusFilters = [
  { value: 'all', label: 'All Leads' },
  { value: 'new', label: 'New' },
  { value: 'contacted', label: 'Contacted' },
  { value: 'customer_waiting', label: 'Customer Waiting' },
  { value: 'scheduled', label: 'Scheduled' },
  { value: 'closed_won', label: 'Closed Won' },
  { value: 'closed_lost', label: 'Closed Lost' },
  { value: 'escalated', label: 'Escalated' },
];

const statusColors: Record<string, string> = {
  new: 'bg-blue-100 text-blue-800',
  contacted: 'bg-yellow-100 text-yellow-800',
  customer_waiting: 'bg-orange-100 text-orange-800',
  scheduled: 'bg-green-100 text-green-800',
  closed_won: 'bg-green-100 text-green-800',
  closed_lost: 'bg-gray-100 text-gray-600',
  escalated: 'bg-red-100 text-red-800',
  opted_out: 'bg-gray-100 text-gray-400',
};

const statusLabels: Record<string, string> = {
  new: 'New',
  contacted: 'Contacted',
  customer_waiting: 'Customer Waiting',
  scheduled: 'Scheduled',
  closed_won: 'Closed Won',
  closed_lost: 'Closed Lost',
  escalated: 'Escalated',
  opted_out: 'Opted Out',
};
---

<AdminPage title="Leads" currentPath="/admin/leads">
  <AdminLayout currentPath="/admin/leads">
    <div class="p-8">
      <!-- Header -->
      <div class="mb-8">
        <h1 class="text-3xl font-bold font-heading text-charcoal mb-2">Leads</h1>
        <p class="text-gray-500">Manage and track your lead pipeline</p>
      </div>

      <!-- Error State -->
      {error && (
        <div class="mb-6 p-4 bg-red-50 border border-red-200 rounded-lg">
          <p class="text-sm text-red-600">{error}</p>
        </div>
      )}

      <!-- Filters -->
      <div class="flex flex-wrap gap-2 mb-6">
        {statusFilters.map((filter) => (
          <a
            href={filter.value === 'all' ? '/admin/leads' : `/admin/leads?status=${filter.value}`}
            class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
              (Astro.url.searchParams.get('status') || 'all') === filter.value
                ? 'bg-charcoal text-white'
                : 'bg-white text-gray-600 hover:bg-gray-50 border border-gray-200'
            }`}
          >
            {filter.label}
          </a>
        ))}
      </div>

      <!-- Leads Table -->
      <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
        <div class="overflow-x-auto">
          <table class="w-full">
            <thead>
              <tr class="border-b border-gray-100">
                <th class="text-left py-4 px-6 text-xs font-medium text-gray-500 uppercase tracking-wider">Lead</th>
                <th class="text-left py-4 px-6 text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                <th class="text-left py-4 px-6 text-xs font-medium text-gray-500 uppercase tracking-wider">Message</th>
                <th class="text-left py-4 px-6 text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
                <th class="text-right py-4 px-6 text-xs font-medium text-gray-500 uppercase tracking-wider">Actions</th>
              </tr>
            </thead>
            <tbody class="divide-y divide-gray-100">
              {leadsData.leads.length === 0 && !error && (
                <tr>
                  <td colspan="5" class="py-12 text-center">
                    <div class="text-gray-400">
                      <p class="text-sm mb-2">No leads yet.</p>
                      <p class="text-xs">Leads will appear here when they come in.</p>
                    </div>
                  </td>
                </tr>
              )}
              {leadsData.leads.map((lead) => (
                <tr class="hover:bg-gray-50 transition-colors">
                  <td class="py-4 px-6">
                    <div class="flex items-center gap-3">
                      <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center text-sm font-medium text-gray-600">
                        {(lead.name || lead.email).charAt(0).toUpperCase()}
                      </div>
                      <div>
                        <p class="font-medium text-charcoal">{lead.name || 'Unknown'}</p>
                        <p class="text-sm text-gray-500">{lead.email}</p>
                        {lead.company && <p class="text-sm text-gray-400">{lead.company}</p>}
                      </div>
                    </div>
                  </td>
                  <td class="py-4 px-6">
                    <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${statusColors[lead.status] || 'bg-gray-100 text-gray-800'}`}>
                      {statusLabels[lead.status] || lead.status}
                    </span>
                  </td>
                  <td class="py-4 px-6">
                    <p class="text-sm text-gray-600 max-w-xs truncate">{lead.message || 'No message'}</p>
                  </td>
                  <td class="py-4 px-6">
                    <span class="text-sm text-gray-500">{new Date(lead.createdAt).toLocaleDateString()}</span>
                  </td>
                  <td class="py-4 px-6 text-right">
                    <div class="flex items-center justify-end gap-2">
                      <a
                        href={`/admin/conversations?leadId=${lead.id}`}
                        class="text-sm text-pounce-orange hover:text-pounce-orange-dark font-medium"
                      >
                        View
                      </a>
                    </div>
                  </td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>

        <!-- Pagination -->
        {leadsData.pagination.totalPages > 1 && (
          <div class="flex items-center justify-between px-6 py-4 border-t border-gray-100">
            <span class="text-sm text-gray-500">
              Page {leadsData.pagination.page} of {leadsData.pagination.totalPages}
            </span>
            <div class="flex gap-2">
              {leadsData.pagination.page > 1 && (
                <a
                  href={`/admin/leads?page=${leadsData.pagination.page - 1}`}
                  class="px-3 py-2 bg-white border border-gray-200 rounded-lg text-sm text-gray-600 hover:bg-gray-50 transition-colors"
                >
                  Previous
                </a>
              )}
              {leadsData.pagination.page < leadsData.pagination.totalPages && (
                <a
                  href={`/admin/leads?page=${leadsData.pagination.page + 1}`}
                  class="px-3 py-2 bg-white border border-gray-200 rounded-lg text-sm text-gray-600 hover:bg-gray-50 transition-colors"
                >
                  Next
                </a>
              )}
            </div>
          </div>
        )}
      </div>
    </div>
  </AdminLayout>
</AdminPage>
