---
import AdminPage from '../../layouts/AdminPage.astro';
import AdminLayout from '../../components/admin/AdminLayout';
import { db, leads, conversations, messages } from '../../lib/db/index.js';
import { eq, desc } from 'drizzle-orm';

const session = Astro.locals.session;
const currentUser = session ? { name: session.name || null, email: session.email } : null;

// Check if we're viewing a specific lead's conversation
const selectedLeadId = Astro.url.searchParams.get('leadId');

// Read leads directly from DB
const allLeads = await db.select().from(leads).orderBy(desc(leads.createdAt)).limit(100);

const statusFilters = [
  { value: 'all', label: 'All Leads' },
  { value: 'new', label: 'New' },
  { value: 'contacted', label: 'Contacted' },
  { value: 'customer_waiting', label: 'Customer Waiting' },
  { value: 'scheduled', label: 'Scheduled' },
  { value: 'closed_won', label: 'Closed Won' },
  { value: 'closed_lost', label: 'Closed Lost' },
  { value: 'escalated', label: 'Escalated' },
];

const statusColors: Record<string, string> = {
  new: 'bg-blue-100 text-blue-800',
  contacted: 'bg-yellow-100 text-yellow-800',
  customer_waiting: 'bg-orange-100 text-orange-800',
  scheduled: 'bg-green-100 text-green-800',
  closed_won: 'bg-green-100 text-green-800',
  closed_lost: 'bg-gray-100 text-gray-600',
  escalated: 'bg-red-100 text-red-800',
  opted_out: 'bg-gray-100 text-gray-400',
};

const statusLabels: Record<string, string> = {
  new: 'New',
  contacted: 'Contacted',
  customer_waiting: 'Customer Waiting',
  scheduled: 'Scheduled',
  closed_won: 'Closed Won',
  closed_lost: 'Closed Lost',
  escalated: 'Escalated',
  opted_out: 'Opted Out',
};

// Filter by status query param
const statusFilter = Astro.url.searchParams.get('status');
const filteredLeads = statusFilter && statusFilter !== 'all'
  ? allLeads.filter(l => l.status === statusFilter)
  : allLeads;

// Load conversation if viewing a specific lead
let selectedLead: any = null;
let selectedConv: any = null;
let convMessages: any[] = [];

if (selectedLeadId) {
  const [lead] = await db.select().from(leads).where(eq(leads.id, selectedLeadId)).limit(1);
  if (lead) {
    selectedLead = lead;
    const [conv] = await db.select().from(conversations).where(eq(conversations.leadId, lead.id)).limit(1);
    if (conv) {
      selectedConv = conv;
      convMessages = await db.select().from(messages).where(eq(messages.conversationId, conv.id)).orderBy(messages.createdAt);
    }
  }
}
---

<AdminPage title={selectedLead ? `Lead: ${selectedLead?.name || selectedLead?.email}` : 'Leads'} currentPath="/admin/leads">
  <AdminLayout currentPath="/admin/leads" currentUser={currentUser}>
    <div class="p-8">
      {selectedLead ? (
        <!-- Conversation View -->
        <div>
          <a href="/admin/leads" class="inline-flex items-center gap-2 text-sm text-gray-500 hover:text-charcoal transition-colors mb-6">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7" />
            </svg>
            Back to Leads
          </a>

          <div class="bg-white rounded-xl shadow-sm border border-gray-100 flex flex-col h-[600px]">
            <!-- Header -->
            <div class="p-4 border-b border-gray-100 flex items-center justify-between">
              <div class="flex items-center gap-3">
                <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center text-sm font-medium text-gray-600">
                  {(selectedLead.name || selectedLead.email).charAt(0).toUpperCase()}
                </div>
                <div>
                  <p class="font-medium text-charcoal">{selectedLead.name || 'Unknown'}</p>
                  <p class="text-sm text-gray-500">{selectedLead.email}{selectedLead.company && ` · ${selectedLead.company}`}</p>
                </div>
              </div>
              <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${statusColors[selectedLead.status] || 'bg-gray-100 text-gray-800'}`}>
                {statusLabels[selectedLead.status] || selectedLead.status}
              </span>
            </div>

            <!-- Messages -->
            <div class="flex-1 overflow-y-auto p-4 space-y-4">
              {convMessages.length === 0 ? (
                <div class="flex-1 flex items-center justify-center text-gray-400">
                  <p class="text-sm">No messages yet.</p>
                </div>
              ) : (
                convMessages.map((message) => (
                  <div class={`flex ${message.source === 'customer' ? 'justify-start' : 'justify-end'}`}>
                    <div class={`max-w-[75%] rounded-2xl px-4 py-3 ${
                      message.source === 'customer'
                        ? 'bg-gray-100 text-charcoal rounded-bl-none'
                        : message.source === 'ai'
                        ? 'bg-[#E8F4FD] text-charcoal rounded-br-none border border-blue-200'
                        : 'bg-[#FEF3E2] text-charcoal rounded-br-none border border-orange-200'
                    }`}>
                      {message.source === 'ai' && (
                        <div class="flex items-center gap-1.5 mb-2 pb-2 border-b border-blue-200/50">
                          <svg class="w-3.5 h-3.5 text-blue-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z" />
                          </svg>
                          <span class="text-xs font-medium text-blue-600">AI responded</span>
                        </div>
                      )}
                      <p class="text-sm leading-relaxed whitespace-pre-wrap">{message.content}</p>
                      <div class="flex items-center gap-2 mt-2">
                        <span class="text-xs text-gray-400">
                          {new Date(message.createdAt).toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' })}
                        </span>
                        {message.source === 'ai' && (
                          <span class="text-xs font-medium text-blue-600">AI</span>
                        )}
                        {message.source === 'human' && (
                          <span class="text-xs font-medium text-orange-600">You</span>
                        )}
                        {message.source === 'customer' && (
                          <span class="text-xs font-medium text-gray-500">Lead</span>
                        )}
                      </div>
                    </div>
                  </div>
                ))
              )}
            </div>
          </div>
        </div>
      ) : (
        <!-- Leads List View -->
        <div>
          <div class="mb-8">
            <h1 class="text-3xl font-bold font-heading text-charcoal mb-2">Leads</h1>
            <p class="text-gray-500">Manage and track your lead pipeline</p>
          </div>

          <!-- Filters -->
          <div class="flex flex-wrap gap-2 mb-6">
            {statusFilters.map((filter) => (
              <a
                href={filter.value === 'all' ? '/admin/leads' : `/admin/leads?status=${filter.value}`}
                class={`px-4 py-2 rounded-lg text-sm font-medium transition-colors ${
                  (Astro.url.searchParams.get('status') || 'all') === filter.value
                    ? 'bg-charcoal text-white'
                    : 'bg-white text-gray-600 hover:bg-gray-50 border border-gray-200'
                }`}
              >
                {filter.label}
              </a>
            ))}
          </div>

          <!-- Leads Table -->
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <div class="overflow-x-auto">
              <table class="w-full">
                <thead>
                  <tr class="border-b border-gray-100">
                    <th class="text-left py-4 px-6 text-xs font-medium text-gray-500 uppercase tracking-wider">Lead</th>
                    <th class="text-left py-4 px-6 text-xs font-medium text-gray-500 uppercase tracking-wider">Status</th>
                    <th class="text-left py-4 px-6 text-xs font-medium text-gray-500 uppercase tracking-wider">Message</th>
                    <th class="text-left py-4 px-6 text-xs font-medium text-gray-500 uppercase tracking-wider">Date</th>
                  </tr>
                </thead>
                <tbody class="divide-y divide-gray-100">
                  {filteredLeads.length === 0 && (
                    <tr>
                      <td colspan="4" class="py-12 text-center">
                        <div class="text-gray-400">
                          <p class="text-sm mb-2">No leads yet.</p>
                          <p class="text-xs">Leads will appear here when they come in.</p>
                        </div>
                      </td>
                    </tr>
                  )}
                  {filteredLeads.map((lead) => (
                    <a href={`/admin/leads?leadId=${lead.id}`} class="contents">
                      <tr class="hover:bg-gray-50 transition-colors cursor-pointer">
                        <td class="py-4 px-6">
                          <div class="flex items-center gap-3">
                            <div class="w-10 h-10 rounded-full bg-gray-100 flex items-center justify-center text-sm font-medium text-gray-600">
                              {(lead.name || lead.email).charAt(0).toUpperCase()}
                            </div>
                            <div>
                              <p class="font-medium text-charcoal">{lead.name || 'Unknown'}</p>
                              <p class="text-sm text-gray-500">{lead.email}</p>
                            </div>
                          </div>
                        </td>
                        <td class="py-4 px-6">
                          <span class={`inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium ${statusColors[lead.status] || 'bg-gray-100 text-gray-800'}`}>
                            {statusLabels[lead.status] || lead.status}
                          </span>
                        </td>
                        <td class="py-4 px-6">
                          <p class="text-sm text-gray-600 max-w-xs truncate">{lead.message || 'No message'}</p>
                        </td>
                        <td class="py-4 px-6">
                          <span class="text-sm text-gray-500">{new Date(lead.createdAt).toLocaleDateString()}</span>
                        </td>
                      </tr>
                    </a>
                  ))}
                </tbody>
              </table>
            </div>
          </div>
        </div>
      )}
    </div>
  </AdminLayout>
</AdminPage>