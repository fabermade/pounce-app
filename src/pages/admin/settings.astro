---
import AdminPage from '../../layouts/AdminPage.astro';
import AdminLayout from '../../components/admin/AdminLayout';

// Mock business config
const businessConfig = {
  business: {
    name: 'Faber Made',
    tagline: 'Custom AI agent teams, crafted by hand',
    website: 'https://fabermade.net',
    description: 'We build custom AI agent teams for businesses that want to automate without losing the human touch.',
  },
  tone: {
    style: 'professional but warm',
    instructions: 'Be concise and direct. No jargon. Use examples when helpful.',
    dos: ['Use first person', 'Be friendly but professional', 'Offer specific next steps'],
    donts: ['Use buzzwords', 'Be overly formal', 'Leave questions unanswered'],
  },
  services: [
    { name: 'AI Team Strategy', description: 'End to end AI team design and implementation', price: 'From $2,000/mo' },
    { name: 'Web Development', description: 'Custom web applications and sites', price: 'Custom quote' },
  ],
  faq: [
    { question: 'How long does setup take?', answer: 'Typically 2 to 4 weeks depending on complexity.' },
    { question: 'Do you use templates?', answer: 'No. Every agent is custom built for your business.' },
  ],
  escalation: {
    triggerPhrases: ['refund', 'cancel', 'lawyer', 'attorney', 'complaint'],
    notifyEmail: 'tyler@fabermade.net',
  },
  booking: {
    url: 'https://cal.com/pounce',
    cta: 'Ready to chat? Book a 30 minute call',
    timing: 'after_second_exchange',
  },
  providers: {
    llm: 'openai',
    email: 'resend',
    inbox: 'resend',
  },
};

const settingsSections = [
  { id: 'business', label: 'Business Identity' },
  { id: 'tone', label: 'Tone & Voice' },
  { id: 'knowledge', label: 'Knowledge Sources' },
  { id: 'services', label: 'Services & Pricing' },
  { id: 'faq', label: 'FAQ' },
  { id: 'escalation', label: 'Escalation Rules' },
  { id: 'booking', label: 'Booking' },
  { id: 'integrations', label: 'Integrations' },
  { id: 'agent', label: 'Agent Mode' },
];
---

<AdminPage title="Settings" currentPath="/admin/settings">
  <AdminLayout currentPath="/admin/settings">
    <div class="p-8">
      <!-- Header -->
      <div class="mb-8">
        <h1 class="text-3xl font-bold font-heading text-charcoal mb-2">Settings</h1>
        <p class="text-gray-500">Configure your AI lead response agent</p>
      </div>

      <!-- BOLT: Need GET /api/admin/config -->
      <!-- BOLT: Need PATCH /api/admin/config -->

      <div class="grid grid-cols-1 lg:grid-cols-4 gap-8">
        <!-- Settings Navigation -->
        <div class="lg:col-span-1">
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 overflow-hidden">
            <nav class="divide-y divide-gray-100">
              {settingsSections.map((section, index) => (
                <button
                  class={`w-full text-left px-4 py-3 text-sm font-medium transition-colors hover:bg-gray-50 ${
                    index === 0 ? 'bg-pounce-orange/10 text-pounce-orange' : 'text-gray-600'
                  }`}
                >
                  {section.label}
                </button>
              ))}
            </nav>
          </div>
        </div>

        <!-- Settings Content -->
        <div class="lg:col-span-3 space-y-6">
          <!-- Business Identity -->
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <h2 class="text-lg font-semibold font-heading text-charcoal mb-4">Business Identity</h2>
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Business Name</label>
                <input
                  type="text"
                  value={businessConfig.business.name}
                  class="w-full px-4 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Tagline</label>
                <input
                  type="text"
                  value={businessConfig.business.tagline}
                  class="w-full px-4 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Website</label>
                <input
                  type="url"
                  value={businessConfig.business.website}
                  class="w-full px-4 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
                />
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Description</label>
                <textarea
                  rows={4}
                  class="w-full px-4 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
                >{businessConfig.business.description}</textarea>
              </div>
            </div>
          </div>

          <!-- Tone & Voice -->
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <h2 class="text-lg font-semibold font-heading text-charcoal mb-4">Tone & Voice</h2>
            <div class="space-y-4">
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Style Preset</label>
                <select class="w-full px-4 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm">
                  <option value="professional">Professional</option>
                  <option value="friendly">Friendly</option>
                  <option value="casual">Casual</option>
                  <option value="formal">Formal</option>
                </select>
              </div>
              <div>
                <label class="block text-sm font-medium text-gray-700 mb-1">Custom Instructions</label>
                <textarea
                  rows={3}
                  class="w-full px-4 py-2 rounded-lg border border-gray-200 focus:outline-none focus:ring-2 focus:ring-pounce-orange/20 focus:border-pounce-orange text-sm"
                >{businessConfig.tone.instructions}</textarea>
              </div>
              <div class="grid grid-cols-2 gap-4">
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-2">Dos</label>
                  <div class="space-y-2">
                    {businessConfig.tone.dos.map((item) => (
                      <div class="flex items-center gap-2">
                        <svg class="w-4 h-4 text-green-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7" />
                        </svg>
                        <span class="text-sm text-gray-600">{item}</span>
                      </div>
                    ))}
                  </div>
                </div>
                <div>
                  <label class="block text-sm font-medium text-gray-700 mb-2">Don'ts</label>
                  <div class="space-y-2">
                    {businessConfig.tone.donts.map((item) => (
                      <div class="flex items-center gap-2">
                        <svg class="w-4 h-4 text-red-500" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
                        </svg>
                        <span class="text-sm text-gray-600">{item}</span>
                      </div>
                    ))}
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Services -->
          <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
            <div class="flex items-center justify-between mb-4">
              <h2 class="text-lg font-semibold font-heading text-charcoal">Services & Pricing</h2>
              <button class="px-4 py-2 bg-pounce-orange text-white rounded-lg text-sm font-medium hover:bg-pounce-orange-dark transition-colors">
                + Add Service
              </button>
            </div>
            <div class="space-y-4">
              {businessConfig.services.map((service) => (
                <div class="p-4 border border-gray-200 rounded-lg">
                  <div class="flex items-center justify-between mb-2">
                    <input
                      type="text"
                      value={service.name}
                      class="font-medium text-charcoal bg-transparent border-none focus:outline-none"
                    />
                    <button class="text-gray-400 hover:text-red-500 transition-colors">
                      <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                      </svg>
                    </button>
                  </div>
                  <input
                    type="text"
                    value={service.description}
                    class="w-full text-sm text-gray-600 bg-transparent border-none focus:outline-none mb-2"
                  />
                  <input
                    type="text"
                    value={service.price}
                    class="text-sm text-pounce-orange font-medium bg-transparent border-none focus:outline-none"
                  />
                </div>
              ))}
            </div>
          </div>

          <!-- Save Button -->
          <div class="flex justify-end">
            <button class="px-6 py-3 bg-charcoal text-white rounded-lg font-medium hover:bg-charcoal-light transition-colors">
              Save Changes
            </button>
          </div>
        </div>
      </div>
    </div>
  </AdminLayout>
</AdminPage>
