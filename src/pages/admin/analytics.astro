---
import AdminPage from '../../layouts/AdminPage.astro';
import AdminLayout from '../../components/admin/AdminLayout';

// Mock analytics data
const stats = {
  totalLeads: 156,
  responseRate: 94,
  avgResponseTime: '2.3',
  bookingRate: 32,
  leadsThisWeek: 23,
  leadsLastWeek: 18,
};

const weeklyData = [
  { day: 'Mon', leads: 4, responses: 4, bookings: 1 },
  { day: 'Tue', leads: 6, responses: 5, bookings: 2 },
  { day: 'Wed', leads: 3, responses: 3, bookings: 0 },
  { day: 'Thu', leads: 5, responses: 5, bookings: 1 },
  { day: 'Fri', leads: 3, responses: 3, bookings: 2 },
  { day: 'Sat', leads: 1, responses: 1, bookings: 0 },
  { day: 'Sun', leads: 1, responses: 1, bookings: 0 },
];

const statusBreakdown = [
  { status: 'New', count: 12, color: 'bg-blue-500' },
  { status: 'Contacted', count: 8, color: 'bg-yellow-500' },
  { status: 'Scheduled', count: 5, color: 'bg-green-500' },
  { status: 'Closed Won', count: 3, color: 'bg-green-600' },
  { status: 'Escalated', count: 2, color: 'bg-red-500' },
];

const recentActivity = [
  { action: 'Lead contacted', target: 'sarah@acme.com', time: '2 min ago' },
  { action: 'Meeting scheduled', target: 'emma@tech.co', time: '15 min ago' },
  { action: 'Lead escalated', target: 'anna@consulting.com', time: '1 hour ago' },
  { action: 'Response sent', target: 'mike@startup.io', time: '2 hours ago' },
  { action: 'Lead closed won', target: 'david@enterprise.com', time: '3 hours ago' },
];
---

<AdminPage title="Analytics" currentPath="/admin/analytics">
  <AdminLayout currentPath="/admin/analytics">
    <div class="p-8">
      <!-- Header -->
      <div class="mb-8">
        <h1 class="text-3xl font-bold font-heading text-charcoal mb-2">Analytics</h1>
        <p class="text-gray-500">Track your lead response performance</p>
      </div>

      <!-- BOLT: Need GET /api/admin/analytics -->

      <!-- Stats Grid -->
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-6 mb-8">
        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
          <p class="text-sm text-gray-500 mb-1">Total Leads</p>
          <div class="flex items-end gap-2">
            <span class="text-3xl font-bold text-charcoal">{stats.totalLeads}</span>
            <span class="text-sm text-green-600 font-medium mb-1">+{stats.leadsThisWeek - stats.leadsLastWeek}</span>
          </div>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
          <p class="text-sm text-gray-500 mb-1">Response Rate</p>
          <div class="flex items-end gap-2">
            <span class="text-3xl font-bold text-charcoal">{stats.responseRate}%</span>
            <span class="text-sm text-green-600 font-medium mb-1">+2%</span>
          </div>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
          <p class="text-sm text-gray-500 mb-1">Avg Response Time</p>
          <div class="flex items-end gap-2">
            <span class="text-3xl font-bold text-charcoal">{stats.avgResponseTime}s</span>
            <span class="text-sm text-green-600 font-medium mb-1">-0.5s</span>
          </div>
        </div>

        <div class="bg-white rounded-xl p-6 shadow-sm border border-gray-100">
          <p class="text-sm text-gray-500 mb-1">Booking Rate</p>
          <div class="flex items-end gap-2">
            <span class="text-3xl font-bold text-charcoal">{stats.bookingRate}%</span>
            <span class="text-sm text-green-600 font-medium mb-1">+5%</span>
          </div>
        </div>
      </div>

      <div class="grid grid-cols-1 lg:grid-cols-2 gap-6">
        <!-- Weekly Activity Chart -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <h2 class="text-lg font-semibold font-heading text-charcoal mb-6">Weekly Activity</h2>
          <div class="space-y-4">
            {weeklyData.map((day) => (
              <div class="flex items-center gap-4">
                <span class="text-sm text-gray-600 w-8">{day.day}</span>
                <div class="flex-1 flex gap-1">
                  <div
                    class="h-6 bg-pounce-orange rounded flex items-center justify-center"
                    style={`width: ${Math.max((day.leads / 6) * 100, 8)}%`}
                  >
                    <span class="text-xs text-white px-2">{day.leads}</span>
                  </div>
                </div>
              </div>
            ))}
          </div>
          <div class="flex items-center gap-6 mt-4 text-xs text-gray-500">
            <div class="flex items-center gap-2">
              <span class="w-3 h-3 bg-pounce-orange rounded"></span>
              Leads
            </div>
          </div>
        </div>

        <!-- Status Breakdown -->
        <div class="bg-white rounded-xl shadow-sm border border-gray-100 p-6">
          <h2 class="text-lg font-semibold font-heading text-charcoal mb-6">Pipeline Status</h2>
          <div class="space-y-4">
            {statusBreakdown.map((item) => (
              <div class="flex items-center gap-4">
                <div class={`w-3 h-3 rounded-full ${item.color}`}></div>
                <span class="text-sm text-gray-600 flex-1">{item.status}</span>
                <span class="text-sm font-medium text-charcoal">{item.count}</span>
                <div class="w-24 bg-gray-100 rounded-full h-2">
                  <div
                    class={`h-2 rounded-full ${item.color}`}
                    style={`width: ${(item.count / 12) * 100}%`}
                  ></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>

      <!-- Recent Activity -->
      <div class="mt-6 bg-white rounded-xl shadow-sm border border-gray-100 p-6">
        <h2 class="text-lg font-semibold font-heading text-charcoal mb-4">Recent Activity</h2>
        <div class="space-y-3">
          {recentActivity.map((activity) => (
            <div class="flex items-center justify-between py-2">
              <div class="flex items-center gap-3">
                <div class="w-2 h-2 bg-pounce-orange rounded-full"></div>
                <span class="text-sm text-gray-600">{activity.action}</span>
                <span class="text-sm text-charcoal font-medium">{activity.target}</span>
              </div>
              <span class="text-xs text-gray-400">{activity.time}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </AdminLayout>
</AdminPage>
